@typeparam TValue
@namespace BlazorBlueprint.Primitives.Select

@* SelectTrigger primitive - headless button that opens the select dropdown *@
@if (_context != null)
{
    <button type="button"
            id="@_context.TriggerId"
            @ref="_buttonElement"
            role="combobox"
            aria-expanded="@_context.IsOpen.ToString().ToLower()"
            aria-controls="@_context.ContentId"
            aria-haspopup="listbox"
            aria-disabled="@_context.Disabled.ToString().ToLower()"
            disabled="@_context.Disabled"
            data-state="@(_context.IsOpen ? "open" : "closed")"
            @onclick="HandleClick"
            @onkeydown="HandleKeyDown"
            @onkeydown:preventDefault="@_shouldPreventDefault"
            @attributes="FilteredAttributes">
        @ChildContent
    </button>
}

@code {
    private bool _shouldPreventDefault;

    [CascadingParameter]
    private SelectContext<TValue>? _context { get; set; }

    private ElementReference _buttonElement;

    /// <summary>
    /// Content to render inside the trigger button.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional attributes to be applied to the button element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Returns AdditionalAttributes with "id" removed (if present),
    /// since the button always uses the context's TriggerId.
    /// </summary>
    private Dictionary<string, object>? FilteredAttributes
    {
        get
        {
            if (AdditionalAttributes == null || !AdditionalAttributes.ContainsKey("id"))
            {
                return AdditionalAttributes;
            }

            var filtered = new Dictionary<string, object>(AdditionalAttributes);
            filtered.Remove("id");
            return filtered.Count > 0 ? filtered : null;
        }
    }

    protected override void OnParametersSet()
    {
        // If a custom id was passed (e.g. for label association in form fields),
        // sync it to the context so click-outside detection and ARIA references
        // use the same id as the actual DOM element.
        if (_context != null
            && AdditionalAttributes != null
            && AdditionalAttributes.TryGetValue("id", out var idObj)
            && idObj is string customId
            && !string.IsNullOrEmpty(customId))
        {
            _context.SetTriggerId(customId);
        }
    }

    private void HandleClick()
    {
        _context?.Toggle(_buttonElement);
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (_context == null || _context.Disabled)
        {
            _shouldPreventDefault = false;
            return;
        }

        switch (args.Key)
        {
            case "Enter":
            case " ": // Space
            case "ArrowDown":
            case "ArrowUp":
                _shouldPreventDefault = true;
                _context.Open(_buttonElement);
                break;
            case "Escape":
                _shouldPreventDefault = true;
                if (_context.IsOpen)
                {
                    _context.Close();
                }
                break;
            default:
                _shouldPreventDefault = false;
                break;
        }
    }
}
