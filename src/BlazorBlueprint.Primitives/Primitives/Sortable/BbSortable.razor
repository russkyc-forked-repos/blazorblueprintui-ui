@namespace BlazorBlueprint.Primitives.Sortable
@typeparam TItem

<div id="@Id"
     role="list"
     aria-label="@AriaLabel"
     @attributes="AdditionalAttributes">
    @foreach (var item in Items ?? [])
    {
        <div @key="item">
            @if (ItemTemplate is not null)
            {
                @ItemTemplate(item)
            }
        </div>
    }
</div>

<div role="status" aria-live="polite" aria-atomic="true" class="sr-only">@_liveAnnouncement</div>
