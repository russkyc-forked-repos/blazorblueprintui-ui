@namespace BlazorBlueprint.Primitives.AlertDialog

@*
    AlertDialog cancel button - dismisses the dialog without action.
*@

<BlazorBlueprint.Primitives.Dialog.BbDialogClose @attributes="AdditionalAttributes">
    @ChildContent
</BlazorBlueprint.Primitives.Dialog.BbDialogClose>

@code {
    /// <summary>
    /// The cancel button content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
