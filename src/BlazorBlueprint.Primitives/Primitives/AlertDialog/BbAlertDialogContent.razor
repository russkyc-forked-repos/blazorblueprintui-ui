@namespace BlazorBlueprint.Primitives.AlertDialog

@*
    AlertDialog content - uses role="alertdialog" and disables escape key dismiss.
    Focus trap and scroll lock are enabled.
*@

<BlazorBlueprint.Primitives.Dialog.BbDialogContent
    role="alertdialog"
    CloseOnEscape="false"
    TrapFocus="true"
    LockScroll="true"
    @attributes="AdditionalAttributes">
    @ChildContent
</BlazorBlueprint.Primitives.Dialog.BbDialogContent>

@code {
    /// <summary>
    /// The content to render inside the alert dialog.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
