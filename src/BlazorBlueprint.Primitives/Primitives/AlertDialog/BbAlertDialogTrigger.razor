@namespace BlazorBlueprint.Primitives.AlertDialog

@* AlertDialog trigger reuses Dialog trigger *@
<BlazorBlueprint.Primitives.Dialog.BbDialogTrigger AsChild="@AsChild" @attributes="AdditionalAttributes">
    @ChildContent
</BlazorBlueprint.Primitives.Dialog.BbDialogTrigger>

@code {
    /// <summary>
    /// The content to display inside the trigger.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// When true, does not render its own button element.
    /// </summary>
    [Parameter]
    public bool AsChild { get; set; } = false;

    /// <summary>
    /// Additional attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
