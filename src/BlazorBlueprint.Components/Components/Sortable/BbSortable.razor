@namespace BlazorBlueprint.Components
@typeparam TItem

<div id="@Id"
     role="list"
     aria-label="@AriaLabel"
     class="@CssClass"
     @attributes="AdditionalAttributes">
    @foreach (var item in Items ?? [])
    {
        @if (ItemTemplate is not null)
        {
            @ItemTemplate(item)
        }
    }
</div>

<div role="status" aria-live="polite" aria-atomic="true" class="sr-only">@_liveAnnouncement</div>
