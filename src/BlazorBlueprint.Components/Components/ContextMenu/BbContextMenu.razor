@namespace BlazorBlueprint.Components

<BlazorBlueprint.Primitives.ContextMenu.BbContextMenu @ref="primitiveRef" Open="@Open" OpenChanged="@OpenChanged">
    @ChildContent
</BlazorBlueprint.Primitives.ContextMenu.BbContextMenu>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    private BlazorBlueprint.Primitives.ContextMenu.BbContextMenu? primitiveRef;

    internal async Task OpenAt(double x, double y)
    {
        if (primitiveRef != null)
        {
            await primitiveRef.OpenAt(x, y);
        }
    }

    internal async Task Close()
    {
        if (primitiveRef != null)
        {
            await primitiveRef.Close();
        }
    }
}
