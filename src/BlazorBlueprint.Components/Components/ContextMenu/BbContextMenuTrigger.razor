@namespace BlazorBlueprint.Components

<BlazorBlueprint.Primitives.ContextMenu.BbContextMenuTrigger class="@CssClass">
    @ChildContent
</BlazorBlueprint.Primitives.ContextMenu.BbContextMenuTrigger>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CssClass => ClassNames.cn(
        "w-fit",
        Class
    );
}
