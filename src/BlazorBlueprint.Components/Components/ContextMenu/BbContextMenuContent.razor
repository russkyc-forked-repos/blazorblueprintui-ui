@namespace BlazorBlueprint.Components

<BlazorBlueprint.Primitives.ContextMenu.BbContextMenuContent Loop="@Loop" class="@CssClass">
    <div class="p-1">
        @ChildContent
    </div>
</BlazorBlueprint.Primitives.ContextMenu.BbContextMenuContent>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool Loop { get; set; } = true;

    private string CssClass => ClassNames.cn(
        "min-w-[8rem] overflow-hidden rounded-md border bg-popover text-popover-foreground shadow-md outline-none",
        "animate-in fade-in-0 zoom-in-95",
        Class
    );
}
