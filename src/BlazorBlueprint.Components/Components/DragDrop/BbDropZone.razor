@* BbDropZone is superseded by BbSortable with DropZone="true".
   This component is kept as a thin alias for backward compatibility. *@
@namespace BlazorBlueprint.Components
@typeparam T where T : notnull

<BbSortable T="T"
            ZoneIdentifier="@ZoneIdentifier"
            DropZone="true"
            ChildContent="@ChildContent"
            DragItemTemplate="@DragItemTemplate"
            EmptyTemplate="@EmptyTemplate"
            CanDrop="@CanDrop"
            AllowExternalDrop="@AllowDrop"
            HandleClass="@HandleClass"
            OnItemDropped="@OnItemDropped"
            AriaLabel="@AriaLabel"
            DragOverClass="@DragOverClass"
            DragOverNoDropClass="@DragOverNoDropClass"
            Class="@Class" />
