@namespace BlazorBlueprint.Components
@typeparam TItem where TItem : notnull

<div class="@CssClass"
     role="list"
     aria-label="@AriaLabel"
     @ref="_container"
     data-drag-list="@_listId">

    @for (var i = 0; i < Items.Count; i++)
    {
        var index = i;
        var item  = Items[i];
        var draggable = IsDraggable(item);

        <div @key="item"
             role="listitem"
             data-drag-index="@index"
             data-drag-disabled="@(!draggable ? "true" : null)"
             aria-roledescription="@(draggable ? "Reorderable item" : null)"
             aria-grabbed="@(_dragging && _dragIndex == index ? "true" : null)"
             class="@GetWrapperClass(item, index)">
            @if (ItemTemplate is not null)
            {
                @ItemTemplate(item)
            }
        </div>
    }

    @if (ShouldShowEmptyHint)
    {
        <div class="bb-drag-empty-hint"
             role="listitem"
             aria-label="Drop here">
            Drop here
        </div>
    }
</div>
