@namespace BlazorBlueprint.Components

<CascadingValue Value="@context" IsFixed="false">
    <div class="@ContainerCssClass" role="region" aria-label="@Localizer["FilterBuilder.FilterBuilderAriaLabel"]">
        <BbFilterGroup Group="@(draftFilter ?? Filter)"
                       Depth="0"
                       IsRoot="true" />

        @if (ShowApplyButton)
        {
            <div class="@ActionsCssClass">
                <BbButton Variant="ButtonVariant.Default"
                          Size="@(Compact ? ButtonSize.Small : ButtonSize.Default)"
                          OnClick="HandleApply">
                    @ApplyButtonText
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline"
                          Size="@(Compact ? ButtonSize.Small : ButtonSize.Default)"
                          OnClick="HandleClear">
                    @ClearButtonText
                </BbButton>
            </div>
        }
    </div>
</CascadingValue>
