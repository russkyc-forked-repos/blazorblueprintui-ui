@namespace BlazorBlueprint.Components
@inject IBbLocalizer Localizer

<ol aria-label="@Localizer["Timeline.Timeline"]" class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this" IsFixed="true">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            <BbTimelineEmpty />
        }
    </CascadingValue>
</ol>
