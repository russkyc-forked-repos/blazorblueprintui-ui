@namespace BlazorBlueprint.Components
@using PrimitiveOrientation = BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation

<BlazorBlueprint.Primitives.ScrollArea.BbScrollArea Orientation="@MappedOrientation"
                                                    class="@CssClass"
                                                    style="@RootStyle">
    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport class="@ComputedViewportClass"
                                                                style="@ViewportStyle">
        @ChildContent
    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport>

    @if (Type != ScrollAreaType.Hidden)
    {
        @if (Orientation is ScrollAreaOrientation.Vertical or ScrollAreaOrientation.Both)
        {
            <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                Orientation="PrimitiveOrientation.Vertical"
                class="@VerticalScrollbarClass">
                <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb class="@ThumbClass" />
            </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
        }
        @if (Orientation is ScrollAreaOrientation.Horizontal or ScrollAreaOrientation.Both)
        {
            <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                Orientation="PrimitiveOrientation.Horizontal"
                class="@HorizontalScrollbarClass">
                <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb class="@ThumbClass" />
            </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
        }
    }
</BlazorBlueprint.Primitives.ScrollArea.BbScrollArea>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? ViewportClass { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public ScrollAreaType Type { get; set; } = ScrollAreaType.Hover;

    [Parameter]
    public ScrollAreaOrientation Orientation { get; set; } = ScrollAreaOrientation.Vertical;

    [Parameter]
    public string? Height { get; set; }

    [Parameter]
    public string? MaxHeight { get; set; }

    /// <summary>
    /// When true, automatically fills the remaining vertical space in a flex column parent container.
    /// The parent element must use <c>display: flex; flex-direction: column</c> with a constrained height.
    /// Takes precedence over <see cref="Height"/> and <see cref="MaxHeight"/> when set.
    /// </summary>
    [Parameter]
    public bool FillContainer { get; set; }

    private PrimitiveOrientation MappedOrientation => Orientation switch
    {
        ScrollAreaOrientation.Vertical => PrimitiveOrientation.Vertical,
        ScrollAreaOrientation.Horizontal => PrimitiveOrientation.Horizontal,
        ScrollAreaOrientation.Both => PrimitiveOrientation.Both,
        _ => PrimitiveOrientation.Vertical
    };

    private string? RootStyle
    {
        get
        {
            if (FillContainer)
            {
                return null;
            }

            var styles = new List<string>();
            if (!string.IsNullOrEmpty(Height))
            {
                styles.Add($"height: {Height}");
            }
            if (!string.IsNullOrEmpty(MaxHeight))
            {
                styles.Add($"max-height: {MaxHeight}");
            }
            return styles.Count > 0 ? string.Join("; ", styles) : null;
        }
    }

    private string? ViewportStyle
    {
        get
        {
            if (FillContainer)
            {
                return null;
            }

            // MaxHeight needs to be on the viewport too, otherwise height: 100%
            // resolves to auto (circular dependency) and the viewport won't scroll.
            if (!string.IsNullOrEmpty(MaxHeight))
            {
                return $"max-height: {MaxHeight}";
            }

            return null;
        }
    }

    private string CssClass => ClassNames.cn(
        "relative group/scrollarea",
        FillContainer ? "flex-1 min-h-0" : null,
        Class
    );

    private string ComputedViewportClass => ClassNames.cn(
        "w-full rounded-[inherit]",
        FillContainer ? "h-full" : null,
        ViewportClass
    );

    private string ScrollbarVisibilityClass => Type switch
    {
        ScrollAreaType.Always => "",
        ScrollAreaType.Hover => "opacity-0 transition-opacity group-hover/scrollarea:opacity-100",
        ScrollAreaType.Auto => "data-[state=hidden]:opacity-0 transition-opacity",
        _ => ""
    };

    private string VerticalScrollbarClass => ClassNames.cn(
        "flex touch-none select-none h-full w-2.5 border-l border-l-transparent p-[1px]",
        ScrollbarVisibilityClass
    );

    private string HorizontalScrollbarClass => ClassNames.cn(
        "flex touch-none select-none flex-col h-2.5 border-t border-t-transparent p-[1px]",
        ScrollbarVisibilityClass
    );

    private string ThumbClass => "relative rounded-full bg-border flex-1";
}
