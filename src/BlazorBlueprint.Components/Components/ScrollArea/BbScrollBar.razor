@namespace BlazorBlueprint.Components
@using PrimitiveOrientation = BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation

<BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
    Orientation="@MappedOrientation"
    class="@CssClass">
    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb class="@ThumbClass" />
</BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>

@code {
    [Parameter]
    public ScrollAreaOrientation Orientation { get; set; } = ScrollAreaOrientation.Vertical;

    [Parameter]
    public string? Class { get; set; }

    private PrimitiveOrientation MappedOrientation => Orientation switch
    {
        ScrollAreaOrientation.Horizontal => PrimitiveOrientation.Horizontal,
        _ => PrimitiveOrientation.Vertical
    };

    private string CssClass => ClassNames.cn(
        "flex touch-none select-none transition-colors",
        Orientation == ScrollAreaOrientation.Vertical
            ? "h-full w-2.5 border-l border-l-transparent p-[1px]"
            : "h-2.5 flex-col border-t border-t-transparent p-[1px]",
        Class
    );

    private string ThumbClass => "relative rounded-full bg-border flex-1";
}
