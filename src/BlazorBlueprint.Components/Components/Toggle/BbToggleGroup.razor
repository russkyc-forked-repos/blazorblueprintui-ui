@namespace BlazorBlueprint.Components
@typeparam TValue
@attribute [CascadingTypeParameter(nameof(TValue))]

<BlazorBlueprint.Primitives.Toggle.BbToggleGroup TValue="TValue"
    Type="@MappedType"
    Value="@Value"
    ValueChanged="@ValueChanged"
    DefaultValue="@DefaultValue"
    Values="@Values"
    ValuesChanged="@ValuesChanged"
    Disabled="@Disabled"
    class="@CssClass">
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</BlazorBlueprint.Primitives.Toggle.BbToggleGroup>

@code {
    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    public EventCallback<TValue?> ValueChanged { get; set; }

    [Parameter]
    public TValue? DefaultValue { get; set; }

    [Parameter]
    public ToggleGroupType Type { get; set; } = ToggleGroupType.Single;

    [Parameter]
    public List<TValue>? Values { get; set; }

    [Parameter]
    public EventCallback<List<TValue>> ValuesChanged { get; set; }

    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    [Parameter]
    public ToggleSize Size { get; set; } = ToggleSize.Default;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private BlazorBlueprint.Primitives.Toggle.ToggleGroupType MappedType =>
        Type == ToggleGroupType.Multiple
            ? BlazorBlueprint.Primitives.Toggle.ToggleGroupType.Multiple
            : BlazorBlueprint.Primitives.Toggle.ToggleGroupType.Single;

    private string CssClass => ClassNames.cn(
        "flex items-center justify-center gap-1",
        Class
    );
}
