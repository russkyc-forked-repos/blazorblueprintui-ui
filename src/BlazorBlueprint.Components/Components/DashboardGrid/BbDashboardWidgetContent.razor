@namespace BlazorBlueprint.Components

<div class="@CssClass">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string CssClass => ClassNames.cn(
        "flex-1 p-4 overflow-auto",
        Class
    );
}
