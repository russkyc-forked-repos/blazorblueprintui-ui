@namespace BlazorBlueprint.Components

<BlazorBlueprint.Primitives.Menubar.BbMenubarContent Loop="@Loop" class="@CssClass">
    @ChildContent
</BlazorBlueprint.Primitives.Menubar.BbMenubarContent>

@code {
    [CascadingParameter]
    public BbMenubarMenu? Menu { get; set; }

    [CascadingParameter]
    public BbMenubar? Context { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public MenubarContentAlign Align { get; set; } = MenubarContentAlign.Start;

    [Parameter]
    public bool Loop { get; set; } = true;

    private string AlignClass => Align switch
    {
        MenubarContentAlign.Start => "left-0",
        MenubarContentAlign.Center => "left-1/2 -translate-x-1/2",
        MenubarContentAlign.End => "right-0",
        _ => "left-0"
    };

    private string CssClass => ClassNames.cn(
        "absolute top-full mt-1 z-50 min-w-[12rem] overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md outline-none",
        "data-[state=open]:animate-in data-[state=closed]:animate-out",
        "data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0",
        "data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95",
        AlignClass,
        Class
    );
}
