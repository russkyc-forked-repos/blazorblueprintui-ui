@namespace BlazorBlueprint.Components
@typeparam TData where TData : class
@attribute [CascadingTypeParameter(nameof(TData))]
@using BlazorBlueprint.Icons.Lucide.Components
@using BlazorBlueprint.Primitives.DataGrid
@inject IBbLocalizer Localizer

<CascadingValue Value="this" IsFixed="true">
    <div class="@ClassNames.cn("w-full", Class)">
        @if (Toolbar != null)
        {
            <div class="flex items-center justify-between py-4">
                @Toolbar
            </div>
        }
        <div @ref="containerRef" class="@ClassNames.cn("relative w-full", Virtualize ? "" : "overflow-auto")">
            @if (IsLoading)
            {
                @if (LoadingTemplate != null)
                {
                    @LoadingTemplate
                }
                else
                {
                    <div class="flex items-center justify-center p-8 text-muted-foreground">
                        <div class="text-sm">@Localizer["DataGrid.Loading"]</div>
                    </div>
                }
            }
            else if ((_groupedRenderItems == null || !_groupedRenderItems.Any()) && !_processedData.Any() && !_gridState.Filtering.HasFilters)
            {
                @if (EmptyTemplate != null)
                {
                    @EmptyTemplate
                }
                else
                {
                    <BbEmpty Title="@Localizer["DataGrid.NoResultsFound"]" Size="EmptySize.Small" />
                }
            }
            else
            {
                RefreshVisibleColumnsCache();
                <BlazorBlueprint.Primitives.DataGrid.BbDataGrid TData="TData"
                    Items="@_processedData"
                    @bind-State="@_gridState"
                    SelectionMode="@GetPrimitiveSelectionMode()"
                    ManualPagination="true"
                    EnableKeyboardNavigation="@EnableKeyboardNavigation"
                    OnSortChange="HandleSortChange"
                    OnSelectionChange="HandleSelectionChange"
                    OnRowClick="HandleRowClick"
                    OnToggleExpand="@(DetailTemplate != null ? EventCallback.Factory.Create<TData>(this, HandleRowExpandToggle) : default)"
                    OnRowContextMenu="@(RowContextMenu != null ? (EventCallback<(TData, double, double)>)EventCallback.Factory.Create<(TData, double, double)>(this, HandleRowContextMenu) : default)"
                    Class="@ClassNames.cn("w-full caption-bottom text-sm", HasTableFixed() ? "table-fixed" : "")"
                    AriaLabel="@AriaLabel">
                    @if (HasTableFixed())
                    {
                        <colgroup>
                            @foreach (var col in _cachedVisibleColumns)
                            {
                                <col style="@GetColumnWidthStyle(col)" />
                            }
                        </colgroup>
                    }
                    <BlazorBlueprint.Primitives.DataGrid.BbDataGridHeader Class="@ClassNames.cn("bg-background", StickyHeader ? "sticky top-0 z-20" : "")">
                        <BlazorBlueprint.Primitives.DataGrid.BbDataGridRow TData="TData" Class="group/row bg-background">
                            @foreach (var column in _cachedVisibleColumns)
                            {
                                var sortDirection = _gridState.Sorting.GetDirection(column.ColumnId);
                                var sortPriority = _gridState.Sorting.GetPriority(column.ColumnId);
                                var isSelectColumn = column.ColumnId == "__select";
                                var isExpandColumn = column.ColumnId == "__expand";
                                var isHierarchyColumn = _hierarchyColumn != null && column.ColumnId == _hierarchyColumn.ColumnId;
                                var isLastLeft = column.ColumnId == _cachedLastLeftId;
                                var isFirstRight = column.ColumnId == _cachedFirstRightId;

                                <BlazorBlueprint.Primitives.DataGrid.BbDataGridHeaderCell TData="TData"
                                    @key="@column.ColumnId"
                                    ColumnId="@column.ColumnId"
                                    Sortable="@column.Sortable"
                                    Reorderable="@(Reorderable && column.Reorderable)"
                                    Class="@GetHeaderCellClass(column, isSelectColumn, isExpandColumn, isLastLeft, isFirstRight)"
                                    style="@GetColumnStyle(column, _cachedVisibleColumns)"
                                    data-pinned="@(column.Pinned != ColumnPinning.None ? "true" : null)">
                                    @if (isExpandColumn)
                                    {
                                        @* Empty spacer — no header control for expand column *@
                                    }
                                    else if (isSelectColumn)
                                    {
                                        <div @onclick:stopPropagation="true">
                                            @if (ShouldShowSelectAllPrompt())
                                            {
                                                <BbDropdownMenu @bind-Open="_selectAllDropdownOpen">
                                                    <BbDropdownMenuTrigger AsChild="false" Class="inline-flex items-center justify-center p-0 bg-transparent border-0 hover:bg-transparent focus:outline-none">
                                                        <BbCheckbox Checked="@IsAllSelected()"
                                                                  Indeterminate="@IsSomeSelected()"
                                                                  AriaLabel="@Localizer["DataGrid.SelectRowsAriaLabel"]"
                                                                  Class="pointer-events-none" />
                                                    </BbDropdownMenuTrigger>
                                                    <BbDropdownMenuContent Side="PopoverSide.Bottom" Align="PopoverAlign.Start">
                                                        <BbDropdownMenuItem OnClick="@HandleSelectAllOnCurrentPage">
                                                            @Localizer["DataGrid.SelectAllOnPage", _processedData.Count()]
                                                        </BbDropdownMenuItem>
                                                        <BbDropdownMenuItem OnClick="@HandleSelectAllItems">
                                                            @Localizer["DataGrid.SelectAllItems", _gridState.Pagination.TotalItems]
                                                        </BbDropdownMenuItem>
                                                        @if (_gridState.Selection.HasSelection)
                                                        {
                                                            <BbDropdownMenuSeparator />
                                                            <BbDropdownMenuItem OnClick="@HandleClearSelection">
                                                                @Localizer["DataGrid.ClearSelection"]
                                                            </BbDropdownMenuItem>
                                                        }
                                                    </BbDropdownMenuContent>
                                                </BbDropdownMenu>
                                            }
                                            else
                                            {
                                                <BbCheckbox Checked="@IsAllSelected()"
                                                          CheckedChanged="@HandleSelectAllChanged"
                                                          Indeterminate="@IsSomeSelected()"
                                                          AriaLabel="@Localizer["DataGrid.SelectAllRows"]" />
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @if (Reorderable && column.Reorderable)
                                        {
                                            <LucideIcon Name="grip-vertical" Class="absolute left-1 top-1/2 -translate-y-1/2 w-3 h-3 text-muted-foreground/40 opacity-0 group-hover/header:opacity-100 transition-opacity pointer-events-none" />
                                        }
                                        <div class="flex items-center gap-2">
                                            @if (ShowExpandAll && isHierarchyColumn)
                                            {
                                                <button type="button"
                                                        class="inline-flex items-center justify-center rounded-md w-6 h-6 hover:bg-muted transition-colors shrink-0"
                                                        aria-label="@(IsAllExpanded ? Localizer["DataGrid.CollapseAll"] : Localizer["DataGrid.ExpandAll"])"
                                                        @onclick="@ToggleExpandAllAsync"
                                                        @onclick:stopPropagation="true">
                                                    <LucideIcon Name="@(IsAllExpanded ? "chevrons-down-up" : "chevrons-up-down")"
                                                               Class="w-4 h-4 text-muted-foreground" />
                                                </button>
                                            }
                                            @if (column.HeaderTemplate != null)
                                            {
                                                @column.HeaderTemplate(new BlazorBlueprint.Primitives.DataGrid.DataGridHeaderContext<TData>
                                                {
                                                    Column = column,
                                                    State = _gridState
                                                })
                                            }
                                            else
                                            {
                                                <span>@column.Title</span>
                                            }
                                            @if (column.Pinned != ColumnPinning.None)
                                            {
                                                <BbTooltip>
                                                    <BbTooltipTrigger AsChild="false" Focusable="false" Class="inline-flex items-center">
                                                        <LucideIcon Name="pin" Class="w-3.5 h-3.5 text-muted-foreground" />
                                                    </BbTooltipTrigger>
                                                    <BbTooltipContent Side="PopoverSide.Bottom">
                                                        @Localizer["DataGrid.PinnedColumnTooltip"]
                                                    </BbTooltipContent>
                                                </BbTooltip>
                                            }
                                            @if (column.Sortable && sortDirection != SortDirection.None)
                                            {
                                                @if (sortDirection == SortDirection.Ascending)
                                                {
                                                    <LucideIcon Name="arrow-up" Class="w-4 h-4" />
                                                }
                                                else
                                                {
                                                    <LucideIcon Name="arrow-down" Class="w-4 h-4" />
                                                }
                                                @if (_gridState.Sorting.Definitions.Count > 1)
                                                {
                                                    <span class="text-xs text-muted-foreground tabular-nums">@sortPriority</span>
                                                }
                                            }
                                            else if (column.Sortable)
                                            {
                                                <LucideIcon Name="arrow-up-down" Class="w-4 h-4 opacity-0 group-hover/header:opacity-50 transition-opacity" />
                                            }
                                            @if (column.Filterable)
                                            {
                                                var hasActiveFilter = _gridState.Filtering.HasFilter(column.ColumnId);
                                                var filterColumn = column;
                                                <div @onclick:stopPropagation="true" class="inline-flex">
                                                    <BbPopover Open="@(GetFilterPopoverOpen(filterColumn.ColumnId))"
                                                               OpenChanged="@(open => SetFilterPopoverOpen(filterColumn.ColumnId, open))">
                                                        <BbPopoverTrigger AsChild="true">
                                                            <BbButton Variant="ButtonVariant.Ghost"
                                                                      Size="ButtonSize.Icon"
                                                                      Class="@ClassNames.cn("w-7 h-7 transition-colors",
                                                                          hasActiveFilter ? "text-primary" : "text-muted-foreground opacity-0 group-hover/header:opacity-100")"
                                                                      AriaLabel="@($"Filter {filterColumn.Title}")">
                                                                <LucideIcon Name="filter" Class="w-3.5 h-3.5" />
                                                            </BbButton>
                                                        </BbPopoverTrigger>
                                                        <BbPopoverContent Side="PopoverSide.Bottom" Align="PopoverAlign.Start" Class="w-72 p-0">
                                                            @{
                                                                var filterField = GetFilterFieldForColumn(filterColumn);
                                                                if (filterField != null)
                                                                {
                                                                    var filterableCol = filterColumn as IFilterableColumn;
                                                                    <BbDataGridColumnFilter
                                                                        ColumnTitle="@filterColumn.Title"
                                                                        FieldType="@filterField.Type"
                                                                        FieldName="@filterField.Name"
                                                                        FilterOptions="@filterableCol?.GetFilterOptions()"
                                                                        CurrentFilter="@_gridState.Filtering.GetFilter(filterColumn.ColumnId)"
                                                                        OnApply="@(condition => HandleColumnFilterChanged(filterColumn.ColumnId, condition))"
                                                                        OnClear="@(() => HandleColumnFilterChanged(filterColumn.ColumnId, null))" />
                                                                }
                                                            }
                                                        </BbPopoverContent>
                                                    </BbPopover>
                                                </div>
                                            }
                                        </div>
                                        @if (Resizable && column.Resizable)
                                        {
                                            <div class="absolute right-0 top-0 bottom-0 w-2 cursor-col-resize hover:bg-primary/20 active:bg-primary/40"
                                                 data-resize-handle="@column.ColumnId"></div>
                                        }
                                    }
                                </BlazorBlueprint.Primitives.DataGrid.BbDataGridHeaderCell>
                            }
                        </BlazorBlueprint.Primitives.DataGrid.BbDataGridRow>
                    </BlazorBlueprint.Primitives.DataGrid.BbDataGridHeader>
                    <BlazorBlueprint.Primitives.DataGrid.BbDataGridBody Class="bg-background">
                        @if (ShowFilterBar && _gridState.Filtering.HasFilters)
                        {
                            <tr class="@ClassNames.cn("border-b bg-muted/30", FilterBarClass)">
                                <td colspan="@_cachedVisibleColumns.Count" class="px-4 py-1.5">
                                    <div class="flex items-center gap-2 text-xs text-muted-foreground">
                                        <LucideIcon Name="filter" Class="w-3.5 h-3.5" />
                                        <span>@Localizer["DataGrid.ActiveFilters", _gridState.Filtering.ActiveFilterCount]</span>
                                        <button type="button"
                                                class="inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs font-medium hover:bg-muted transition-colors"
                                                @onclick="ClearAllFiltersAsync"
                                                @onclick:stopPropagation="true">
                                            <LucideIcon Name="x" Class="w-3 h-3" />
                                            @Localizer["DataGrid.ClearAll"]
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!_processedData.Any() && _gridState.Filtering.HasFilters)
                        {
                            <tr>
                                <td colspan="@_cachedVisibleColumns.Count" class="py-8 text-center">
                                    <BbEmpty Title="@Localizer["DataGrid.NoResultsFound"]" Description="@Localizer["DataGrid.NoResultsFilterDescription"]" Size="EmptySize.Small" />
                                </td>
                            </tr>
                        }
                        else if (_groupedRenderItems != null)
                        {
                            @foreach (var renderItem in _groupedRenderItems)
                            {
                                @if (renderItem.IsGroupHeader)
                                {
                                    var group = renderItem.GroupRow!;
                                    var groupKey = group.Key ?? "(empty)";
                                    var isCollapsed = _gridState.Grouping.IsCollapsed(groupKey);
                                    var effectiveTemplate = _groupColumnHeaderTemplate ?? GroupHeaderTemplate;
                                    var groupContext = new DataGridGroupContext<TData>
                                    {
                                        Group = group,
                                        IsCollapsed = isCollapsed,
                                        VisibleColumnCount = _cachedVisibleColumns.Count,
                                        ToggleCollapse = EventCallback.Factory.Create(this, () => HandleGroupToggle(group))
                                    };

                                    @if (effectiveTemplate != null)
                                    {
                                        <tr role="row" class="bg-muted/50 border-b font-medium">
                                            <td role="gridcell" colspan="@_cachedVisibleColumns.Count" class="px-4 py-2">
                                                @effectiveTemplate(groupContext)
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        var groupLabelColSpan = GetGroupLabelColSpan(group);
                                        <tr role="row" class="bg-muted/50 border-b font-medium">
                                            <td role="gridcell" colspan="@groupLabelColSpan" class="px-4 py-2">
                                                <div class="flex items-center gap-2">
                                                    <button type="button"
                                                            class="inline-flex items-center justify-center rounded-md w-6 h-6 hover:bg-muted transition-colors"
                                                            aria-expanded="@(!isCollapsed)"
                                                            aria-label="@(isCollapsed ? Localizer["DataGrid.ExpandGroup"] : Localizer["DataGrid.CollapseGroup"])"
                                                            @onclick="groupContext.ToggleCollapse"
                                                            @onclick:stopPropagation="true">
                                                        <LucideIcon Name="@(isCollapsed ? "chevron-right" : "chevron-down")" Class="w-4 h-4" />
                                                    </button>
                                                    <span>@group.ColumnTitle: @(groupKey.ToString())</span>
                                                    <span class="text-muted-foreground text-sm">@Localizer["DataGrid.GroupItemCount", group.ItemCount]</span>
                                                </div>
                                            </td>
                                            @foreach (var col in GetGroupAggregateColumns(group))
                                            {
                                                <td role="gridcell" class="px-4 py-2 text-muted-foreground text-sm">
                                                    @if (group.Aggregates.TryGetValue(col.ColumnId, out var agg))
                                                    {
                                                        <span>@FormatAggregateName(agg.Function): @FormatAggregateValue(agg.Value, agg.Format)</span>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else if (renderItem.IsChildPagerRow)
                                {
                                    var pagerDepth = renderItem.Depth;
                                    var pagerParentValue = renderItem.ParentValue!;
                                    var pagerPageIndex = renderItem.ChildPageIndex;
                                    var pagerTotalChildren = renderItem.TotalChildren;
                                    var pagerPageSize = ChildPageSize ?? 10;
                                    var pagerStart = pagerPageIndex * pagerPageSize + 1;
                                    var pagerEnd = Math.Min((pagerPageIndex + 1) * pagerPageSize, pagerTotalChildren);
                                    var pagerTotalPages = (int)Math.Ceiling((double)pagerTotalChildren / pagerPageSize);
                                    var pagerIndent = pagerDepth * GetHierarchyIndentSize();

                                    <tr role="row" class="border-b bg-muted/30">
                                        <td role="gridcell" colspan="@_cachedVisibleColumns.Count" class="px-4 py-1.5">
                                            <div class="flex items-center gap-2 text-xs text-muted-foreground" style="@($"padding-left: {pagerIndent}px")">
                                                <span>@Localizer["DataGrid.ShowingRange", pagerStart, pagerEnd, pagerTotalChildren]</span>
                                                <div class="flex items-center gap-0.5">
                                                    <button type="button"
                                                            class="inline-flex items-center justify-center rounded w-6 h-6 hover:bg-muted transition-colors disabled:opacity-50"
                                                            disabled="@(pagerPageIndex <= 0)"
                                                            @onclick="@(() => HandleChildPageChange(pagerParentValue, pagerPageIndex - 1))"
                                                            @onclick:stopPropagation="true"
                                                            aria-label="@Localizer["DataGrid.PreviousPage"]">
                                                        <LucideIcon Name="chevron-left" Class="w-3.5 h-3.5" />
                                                    </button>
                                                    <span class="tabular-nums px-1">@(pagerPageIndex + 1) / @pagerTotalPages</span>
                                                    <button type="button"
                                                            class="inline-flex items-center justify-center rounded w-6 h-6 hover:bg-muted transition-colors disabled:opacity-50"
                                                            disabled="@(pagerPageIndex >= pagerTotalPages - 1)"
                                                            @onclick="@(() => HandleChildPageChange(pagerParentValue, pagerPageIndex + 1))"
                                                            @onclick:stopPropagation="true"
                                                            aria-label="@Localizer["DataGrid.NextPage"]">
                                                        <LucideIcon Name="chevron-right" Class="w-3.5 h-3.5" />
                                                    </button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else if (renderItem.IsDataRow && IsInHierarchyMode)
                                {
                                    @RenderHierarchyRow(renderItem)
                                }
                                else
                                {
                                    @RenderDataRow(renderItem.Item!)
                                    @if (DetailTemplate != null && _gridState.Expanded.IsExpanded(renderItem.Item!))
                                    {
                                        <tr class="border-b">
                                            <td colspan="@_cachedVisibleColumns.Count" class="p-4">
                                                @DetailTemplate(renderItem.Item!)
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        }
                        else if (Virtualize && ItemSize > 0)
                        {
                            <Microsoft.AspNetCore.Components.Web.Virtualization.Virtualize Items="@_processedDataList" Context="item" ItemSize="@ItemSize" OverscanCount="5">
                                @RenderDataRow(item)
                            </Microsoft.AspNetCore.Components.Web.Virtualization.Virtualize>
                        }
                        else
                        {
                            @foreach (var item in _processedData)
                            {
                                @RenderDataRow(item)
                                @if (DetailTemplate != null && _gridState.Expanded.IsExpanded(item))
                                {
                                    <tr class="border-b">
                                        <td colspan="@_cachedVisibleColumns.Count" class="p-4">
                                            @DetailTemplate(item)
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </BlazorBlueprint.Primitives.DataGrid.BbDataGridBody>
                </BlazorBlueprint.Primitives.DataGrid.BbDataGrid>
            }
        </div>

        @if (RowContextMenu != null)
        {
            <BbContextMenu @ref="rowContextMenu">
                <BbContextMenuContent>
                    @if (contextMenuItem != null)
                    {
                        @RowContextMenu(new DataGridRowMenuContext<TData>
                        {
                            Item = contextMenuItem,
                            SelectedItems = _gridState.Selection.SelectedItems,
                            VisibleColumns = GetVisibleDataColumns(),
                            CopyToClipboardAsync = CopyToClipboardAsync
                        })
                    }
                </BbContextMenuContent>
            </BbContextMenu>
        }

        @if (ShowPagination && !IsLoading && _processedData.Any())
        {
            <BbPagination State="@_gridState.Pagination"
                        PageSizes="@PageSizes"
                        OnPageChanged="@HandlePageChanged"
                        OnPageSizeChanged="@HandlePageSizeChanged"
                        Class="flex items-center justify-between px-2 py-4">
                <BbPaginationInfo>
                    @if (_gridState.Selection.HasSelection)
                    {
                        <span>@Localizer["DataGrid.RowsSelected", _gridState.Selection.SelectedCount, _gridState.Pagination.TotalItems]</span>
                    }
                </BbPaginationInfo>
                <BbPaginationContent Class="flex items-center gap-6 lg:gap-8">
                    <BbPaginationPageSizeSelector />
                    <div class="flex items-center gap-2">
                        <BbPaginationPageDisplay />
                        <div class="flex items-center gap-1">
                            <BbPaginationItem><BbPaginationFirst /></BbPaginationItem>
                            <BbPaginationItem><BbPaginationPrevious ShowText="false" /></BbPaginationItem>
                            <BbPaginationItem><BbPaginationNext ShowText="false" /></BbPaginationItem>
                            <BbPaginationItem><BbPaginationLast /></BbPaginationItem>
                        </div>
                    </div>
                </BbPaginationContent>
            </BbPagination>
        }
    </div>

    @* Capture column definitions from child components *@
    @Columns
</CascadingValue>

@code {
    private string FormatAggregateName(AggregateFunction function) => function switch
    {
        AggregateFunction.Count => Localizer["DataGrid.CountLabel"],
        AggregateFunction.Sum => Localizer["DataGrid.SumLabel"],
        AggregateFunction.Average => Localizer["DataGrid.AverageLabel"],
        AggregateFunction.Min => Localizer["DataGrid.MinLabel"],
        AggregateFunction.Max => Localizer["DataGrid.MaxLabel"],
        _ => ""
    };

    private static string FormatAggregateValue(object? value, string? format)
    {
        if (value == null)
        {
            return "-";
        }

        if (!string.IsNullOrEmpty(format) && value is IFormattable formattable)
        {
            return formattable.ToString(format, System.Globalization.CultureInfo.CurrentCulture);
        }

        if (value is double d)
        {
            // Use integer format when the value has no fractional part
            return d == Math.Truncate(d)
                ? d.ToString("N0", System.Globalization.CultureInfo.CurrentCulture)
                : d.ToString("N2", System.Globalization.CultureInfo.CurrentCulture);
        }

        return value.ToString() ?? "-";
    }

    private RenderFragment<TData> RenderDataRow => item =>
        @<BlazorBlueprint.Primitives.DataGrid.BbDataGridRow TData="TData" Item="@item"
            Class="@ClassNames.cn("group/row bg-background", RowClass?.Invoke(item))">
            @foreach (var column in _cachedVisibleColumns)
            {
                var isSelectColumn = column.ColumnId == "__select";
                var isExpandColumn = column.ColumnId == "__expand";
                var isLastLeft = column.ColumnId == _cachedLastLeftId;
                var isFirstRight = column.ColumnId == _cachedFirstRightId;
                var pinnedStyle = GetPinnedStyle(column, _cachedVisibleColumns);

                <BlazorBlueprint.Primitives.DataGrid.BbDataGridCell
                    @key="@column.ColumnId"
                    Class="@GetCellClass(column, isSelectColumn, isExpandColumn, isLastLeft, isFirstRight)"
                    style="@pinnedStyle"
                    data-pinned="@(column.Pinned != ColumnPinning.None ? "true" : null)">
                    @if (isExpandColumn)
                    {
                        @if (DetailTemplate != null)
                        {
                            var isExpanded = _gridState.Expanded.IsExpanded(item);
                            <button type="button"
                                    class="inline-flex items-center justify-center rounded-md w-8 h-8 hover:bg-muted transition-colors"
                                    aria-expanded="@isExpanded.ToString().ToLowerInvariant()"
                                    aria-label="@(isExpanded ? Localizer["DataGrid.CollapseRow"] : Localizer["DataGrid.ExpandRow"])"
                                    @onclick="@(() => HandleRowExpandToggle(item))"
                                    @onclick:stopPropagation="true">
                                <LucideIcon Name="@(isExpanded ? "chevron-down" : "chevron-right")" Class="w-4 h-4" />
                            </button>
                        }
                    }
                    else if (isSelectColumn)
                    {
                        <div @onclick:stopPropagation="true">
                            <BbCheckbox Checked="@_gridState.Selection.IsSelected(item)"
                                      CheckedChanged="@((bool isChecked) => HandleRowSelectionChanged(item, isChecked))"
                                      AriaLabel="@Localizer["DataGrid.SelectThisRow"]" />
                        </div>
                    }
                    else if (column.CellTemplate != null)
                    {
                        @column.CellTemplate(new BlazorBlueprint.Primitives.DataGrid.DataGridCellContext<TData>
                        {
                            Item = item,
                            Column = column,
                            Value = column.GetValue(item)
                        })
                    }
                    else
                    {
                        @(column.GetValue(item)?.ToString() ?? "")
                    }
                </BlazorBlueprint.Primitives.DataGrid.BbDataGridCell>
            }
        </BlazorBlueprint.Primitives.DataGrid.BbDataGridRow>;

    private RenderFragment<DataGridRenderItem<TData>> RenderHierarchyRow => renderItem =>
    {
        var item = renderItem.Item!;
        var rowClass = ClassNames.cn("group/row bg-background",
            !renderItem.MatchesFilter ? "opacity-50" : "",
            RowClass?.Invoke(item));

        return @<BlazorBlueprint.Primitives.DataGrid.BbDataGridRow @key="@ItemValueSelector!(item)" TData="TData" Item="@item"
            Class="@rowClass"
            aria-level="@(renderItem.Depth + 1)">
            @foreach (var column in _cachedVisibleColumns)
            {
                var isSelectColumn = column.ColumnId == "__select";
                var isExpandColumn = column.ColumnId == "__expand";
                var isHierarchyColumn = _hierarchyColumn != null && column.ColumnId == _hierarchyColumn.ColumnId;
                var isLastLeft = column.ColumnId == _cachedLastLeftId;
                var isFirstRight = column.ColumnId == _cachedFirstRightId;
                var pinnedStyle = GetPinnedStyle(column, _cachedVisibleColumns);

                <BlazorBlueprint.Primitives.DataGrid.BbDataGridCell
                    @key="@column.ColumnId"
                    Class="@GetCellClass(column, isSelectColumn, isExpandColumn, isLastLeft, isFirstRight)"
                    style="@pinnedStyle"
                    data-pinned="@(column.Pinned != ColumnPinning.None ? "true" : null)">
                    @if (isSelectColumn)
                    {
                        <div @onclick:stopPropagation="true">
                            <BbCheckbox Checked="@_gridState.Selection.IsSelected(item)"
                                      Indeterminate="@IsHierarchyItemIndeterminate(item)"
                                      CheckedChanged="@((bool isChecked) => HandleRowSelectionChanged(item, isChecked))"
                                      AriaLabel="@Localizer["DataGrid.SelectThisRow"]" />
                        </div>
                    }
                    else if (isHierarchyColumn)
                    {
                        var indent = renderItem.Depth * GetHierarchyIndentSize();
                        <div class="flex items-center" style="@($"padding-left: {indent}px")">
                            @if (renderItem.HasChildren)
                            {
                                <button type="button"
                                        class="inline-flex items-center justify-center rounded-md w-6 h-6 mr-1 hover:bg-muted transition-colors shrink-0"
                                        aria-expanded="@renderItem.IsExpanded.ToString().ToLowerInvariant()"
                                        aria-label="@(renderItem.IsExpanded ? Localizer["DataGrid.Collapse"] : Localizer["DataGrid.Expand"])"
                                        @onclick="@(() => HandleHierarchyNodeToggle(item))"
                                        @onclick:stopPropagation="true">
                                    <LucideIcon Name="@(renderItem.IsExpanded ? "chevron-down" : "chevron-right")"
                                               Class="w-4 h-4 transition-transform" />
                                </button>
                            }
                            else
                            {
                                <span class="inline-block w-6 mr-1 shrink-0"></span>
                            }
                            @if (column.CellTemplate != null)
                            {
                                @column.CellTemplate(new BlazorBlueprint.Primitives.DataGrid.DataGridCellContext<TData>
                                {
                                    Item = item,
                                    Column = column,
                                    Value = column.GetValue(item)
                                })
                            }
                            else
                            {
                                <span class="truncate">@(column.GetValue(item)?.ToString() ?? "")</span>
                            }
                        </div>
                    }
                    else if (column.CellTemplate != null)
                    {
                        @column.CellTemplate(new BlazorBlueprint.Primitives.DataGrid.DataGridCellContext<TData>
                        {
                            Item = item,
                            Column = column,
                            Value = column.GetValue(item)
                        })
                    }
                    else
                    {
                        @(column.GetValue(item)?.ToString() ?? "")
                    }
                </BlazorBlueprint.Primitives.DataGrid.BbDataGridCell>
            }
        </BlazorBlueprint.Primitives.DataGrid.BbDataGridRow>;
    };

    private int GetHierarchyIndentSize()
    {
        // Check if the hierarchy column has a custom indent size
        // Default to 24px
        return 24;
    }
}
