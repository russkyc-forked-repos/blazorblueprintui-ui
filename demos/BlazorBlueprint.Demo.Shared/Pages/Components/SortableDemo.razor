@page "/components/drag-drop"
@page "/components/sortable"

<PageTitle>DragDrop Component - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-4xl">
    <div>
        <div class="space-y-3">
            <h1 class="text-4xl font-bold tracking-tight">DragDrop</h1>
            <p class="text-xl text-muted-foreground">
                Drag-and-drop sortable list powered by SortableJS. Supports in-list reordering,
                cross-list transfers, handles, clone mode, and filtering — all in one component.
            </p>
        </div>
    </div>

    @* ── 1. Basic reorder ──────────────────────────────────────────────── *@
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Basic Reorder</h2>
            <p class="text-sm text-muted-foreground">
                Drag items to reorder. Handle <code class="text-xs bg-muted px-1 py-0.5 rounded">OnUpdate</code>
                to apply the new order to your list.
            </p>
        </div>

        <BbDragDrop TItem="BasicItem"
                    Items="_basicItems"
                    OnUpdate="@(args => SortList(_basicItems, args))"
                    Class="flex flex-col gap-2">
            <ItemTemplate Context="item">
                <div class="flex items-center gap-3 p-3 rounded-lg border bg-card text-card-foreground shadow-sm select-none cursor-grab active:cursor-grabbing">
                    <span class="text-muted-foreground text-lg" aria-hidden="true">⠿</span>
                    <span class="text-sm font-medium">@item.Title</span>
                </div>
            </ItemTemplate>
        </BbDragDrop>
    </div>

    @* ── 2. Drag handle ────────────────────────────────────────────────── *@
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Drag Handle</h2>
            <p class="text-sm text-muted-foreground">
                Set <code class="text-xs bg-muted px-1 py-0.5 rounded">Handle</code> to a CSS class inside
                your item template. Only that element will initiate a drag.
            </p>
        </div>

        <BbDragDrop TItem="BasicItem"
                    Items="_handleItems"
                    Handle="bb-drag-handle"
                    OnUpdate="@(args => SortList(_handleItems, args))"
                    Class="flex flex-col gap-2">
            <ItemTemplate Context="item">
                <div class="flex items-center gap-3 p-3 rounded-lg border bg-card text-card-foreground shadow-sm select-none">
                    <span class="bb-drag-handle text-muted-foreground text-lg cursor-grab hover:text-foreground transition-colors"
                          title="Drag handle" aria-hidden="true">⠿</span>
                    <span class="text-sm font-medium flex-1">@item.Title</span>
                    <BbBadge Variant="BadgeVariant.Secondary" Class="text-xs">handle only</BbBadge>
                </div>
            </ItemTemplate>
        </BbDragDrop>
    </div>

    @* ── 3. Kanban board (cross-list) ──────────────────────────────────── *@
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Kanban Board</h2>
            <p class="text-sm text-muted-foreground">
                Multiple lists share the same <code class="text-xs bg-muted px-1 py-0.5 rounded">Group</code>.
                Handle <code class="text-xs bg-muted px-1 py-0.5 rounded">OnUpdate</code> for same-column reorder,
                <code class="text-xs bg-muted px-1 py-0.5 rounded">OnRemove</code> to remove from source, and
                <code class="text-xs bg-muted px-1 py-0.5 rounded">OnAdd</code> to insert into target.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            @foreach (var col in _kanbanColumns)
            {
                var column = col;
                <div class="flex flex-col gap-2 rounded-xl border bg-muted/30 p-3 min-h-[200px]">
                    <div class="flex items-center justify-between px-1 pb-1">
                        <h3 class="text-sm font-semibold">@column.Name</h3>
                        <span class="text-xs text-muted-foreground bg-muted rounded-full px-2 py-0.5">
                            @column.Cards.Count
                        </span>
                    </div>

                    <BbDragDrop TItem="KanbanCard"
                                Items="column.Cards"
                                Group="kanban"
                                OnUpdate="@(args => SortList(column.Cards, args))"
                                OnRemove="@(args => column.Cards.RemoveAt(args.OldIndex))"
                                OnAdd="@(args => HandleKanbanAdd(column, args))"
                                Class="flex flex-col gap-2 flex-1 min-h-[3rem]">
                        <ItemTemplate Context="card">
                            <BbCard Class="cursor-grab active:cursor-grabbing shadow-sm hover:shadow-md transition-shadow duration-200">
                                <BbCardContent Class="p-3 space-y-1">
                                    <p class="text-sm font-medium">@card.Title</p>
                                    <p class="text-xs text-muted-foreground">@card.Description</p>
                                </BbCardContent>
                            </BbCard>
                        </ItemTemplate>
                    </BbDragDrop>
                </div>
            }
        </div>
    </div>

    @* ── 4. Clone mode ─────────────────────────────────────────────────── *@
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Clone Mode</h2>
            <p class="text-sm text-muted-foreground">
                Set <code class="text-xs bg-muted px-1 py-0.5 rounded">Pull="clone"</code> on the source list.
                Dragging to the target duplicates the item — the original stays in place.
            </p>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
                <h3 class="text-sm font-semibold text-muted-foreground">Source (items stay)</h3>
                <BbDragDrop TItem="BasicItem"
                            Items="_cloneSource"
                            Group="clone-group"
                            Pull="clone"
                            Sort="true"
                            OnUpdate="@(args => SortList(_cloneSource, args))"
                            Class="flex flex-col gap-2">
                    <ItemTemplate Context="item">
                        <div class="flex items-center gap-2 p-3 rounded-lg border bg-card text-sm select-none cursor-grab">
                            <span aria-hidden="true">📌</span>
                            <span>@item.Title</span>
                        </div>
                    </ItemTemplate>
                </BbDragDrop>
            </div>
            <div class="space-y-2">
                <h3 class="text-sm font-semibold text-muted-foreground">Target (receives copies)</h3>
                <BbDragDrop TItem="BasicItem"
                            Items="_cloneTarget"
                            Group="clone-group"
                            OnUpdate="@(args => SortList(_cloneTarget, args))"
                            OnAdd="@(args => _cloneTarget.Insert(Math.Clamp(args.NewIndex, 0, _cloneTarget.Count), _cloneSource[args.OldIndex]))"
                            Class="flex flex-col gap-2 min-h-[60px] rounded-lg border-2 border-dashed border-muted-foreground/30 p-2">
                    <ItemTemplate Context="item">
                        <div class="flex items-center gap-2 p-3 rounded-lg border bg-card text-sm select-none cursor-grab">
                            <span aria-hidden="true">📎</span>
                            <span>@item.Title</span>
                        </div>
                    </ItemTemplate>
                </BbDragDrop>
                @if (_cloneTarget.Count > 0)
                {
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small"
                              OnClick="@(() => _cloneTarget.Clear())">
                        Clear
                    </BbButton>
                }
            </div>
        </div>
    </div>

    @* ── 5. Filtering (non-draggable items) ───────────────────────────── *@
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Filtered / Locked Items</h2>
            <p class="text-sm text-muted-foreground">
                Set <code class="text-xs bg-muted px-1 py-0.5 rounded">Filter</code> to a CSS class.
                Elements with that class cannot be dragged.
            </p>
        </div>

        <BbDragDrop TItem="LockedItem"
                    Items="_lockedItems"
                    Filter="bb-item-locked"
                    OnUpdate="@(args => SortList(_lockedItems, args))"
                    Class="flex flex-col gap-2">
            <ItemTemplate Context="item">
                <div class="flex items-center gap-3 p-3 rounded-lg border bg-card text-sm select-none @(item.Locked ? "bb-item-locked opacity-60" : "cursor-grab")">
                    @if (item.Locked)
                    {
                        <span aria-label="Locked">🔒</span>
                    }
                    else
                    {
                        <span class="text-muted-foreground" aria-hidden="true">⠿</span>
                    }
                    <span>@item.Title</span>
                    @if (item.Locked)
                    {
                        <BbBadge Variant="BadgeVariant.Secondary" Class="ml-auto text-xs">Locked</BbBadge>
                    }
                </div>
            </ItemTemplate>
        </BbDragDrop>
    </div>

    @* ── API Reference ──────────────────────────────────────────────────── *@
    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">API Reference</h2>
            <p class="text-muted-foreground">Component properties and parameters.</p>
        </div>

        <ApiReference ComponentName="BbDragDrop&lt;TItem&gt;">
            <ApiParameter Name="Id" Type="string" Default="(auto GUID)">
                HTML <code class="text-xs bg-muted px-1 py-0.5 rounded">id</code> attribute on the list element.
            </ApiParameter>
            <ApiParameter Name="Items" Type="IList&lt;TItem&gt;">
                The list of items to render. Mutate this list in your callbacks to persist changes.
            </ApiParameter>
            <ApiParameter Name="ItemTemplate" Type="RenderFragment&lt;TItem&gt;?">
                Template for each item.
            </ApiParameter>
            <ApiParameter Name="Group" Type="string?" Default="null">
                SortableJS group name. Lists with the same group can exchange items.
            </ApiParameter>
            <ApiParameter Name="Pull" Type="string?" Default="null">
                <code class="text-xs bg-muted px-1 py-0.5 rounded">null</code> = move,
                <code class="text-xs bg-muted px-1 py-0.5 rounded">"clone"</code> = clone items on cross-list drag.
            </ApiParameter>
            <ApiParameter Name="Put" Type="bool" Default="true">
                Whether to accept drops from other lists in the same group.
            </ApiParameter>
            <ApiParameter Name="Sort" Type="bool" Default="true">
                Whether items within this list can be reordered.
            </ApiParameter>
            <ApiParameter Name="Handle" Type="string?" Default="null">
                CSS class of the drag-handle element inside each item.
            </ApiParameter>
            <ApiParameter Name="Filter" Type="string?" Default="null">
                CSS class that marks items as non-draggable.
            </ApiParameter>
            <ApiParameter Name="Animation" Type="int" Default="150">
                Drag animation duration in milliseconds. Set to 0 to disable.
            </ApiParameter>
            <ApiParameter Name="ForceFallback" Type="bool" Default="false">
                Use SortableJS polyfill instead of native HTML5 drag events.
            </ApiParameter>
            <ApiParameter Name="OnUpdate" Type="EventCallback&lt;(int OldIndex, int NewIndex)&gt;">
                Fired when an item is reordered within this list. Reorder your list in this handler.
            </ApiParameter>
            <ApiParameter Name="OnRemove" Type="EventCallback&lt;(int OldIndex, int NewIndex)&gt;">
                Fired when an item is dragged out to another group list. Remove item at OldIndex.
            </ApiParameter>
            <ApiParameter Name="OnAdd" Type="EventCallback&lt;(int OldIndex, int NewIndex)&gt;">
                Fired when an item from another group list is dropped here. Insert item at NewIndex.
            </ApiParameter>
            <ApiParameter Name="Class" Type="string?">
                Additional CSS classes for the list container.
            </ApiParameter>
        </ApiReference>
    </section>
</div>

@code {
    // ── Basic reorder ─────────────────────────────────────────────────────
    private record BasicItem(string Title);

    private List<BasicItem> _basicItems =
    [
        new("Design system tokens"),
        new("Build component library"),
        new("Write documentation"),
        new("Add unit tests"),
        new("Publish to NuGet"),
    ];

    // ── Handle demo ───────────────────────────────────────────────────────
    private List<BasicItem> _handleItems =
    [
        new("Drag the grip icon only"),
        new("Clicking the text does nothing"),
        new("Only the ⠿ icon initiates drag"),
        new("Try clicking the badge vs the handle"),
    ];

    // ── Kanban board ──────────────────────────────────────────────────────
    private record KanbanCard(string Id, string Title, string Description);

    private sealed class KanbanColumn(string id, string name)
    {
        public string Id   { get; } = id;
        public string Name { get; } = name;
        public List<KanbanCard> Cards { get; } = [];
    }

    // Flat list of all kanban cards shared across columns
    private List<KanbanCard> _allCards =
    [
        new("k1", "Design mockups",    "Create UI wireframes for all components"),
        new("k2", "Write specs",       "Document the API surface"),
        new("k3", "Set up CI/CD",      "GitHub Actions pipeline"),
        new("k4", "Build core API",    "REST endpoints and authentication"),
        new("k5", "Component library", "Blazor Blueprint integration"),
        new("k6", "Project scaffold",  "Repository and solution setup"),
    ];

    private List<KanbanColumn> _kanbanColumns =
    [
        new("todo",  "To Do"),
        new("doing", "In Progress"),
        new("done",  "Done"),
    ];

    protected override void OnInitialized()
    {
        _kanbanColumns[0].Cards.AddRange(_allCards.Take(3));
        _kanbanColumns[1].Cards.AddRange(_allCards.Skip(3).Take(2));
        _kanbanColumns[2].Cards.AddRange(_allCards.Skip(5));
    }

    private void HandleKanbanAdd(KanbanColumn targetCol, (int OldIndex, int NewIndex) args)
    {
        // Find the card that SortableJS moved (it was already physically moved in DOM).
        // We need to find the source column and get the card at OldIndex.
        // Since OnRemove already ran on the source and removed the card from that column's list,
        // we search all cards for the one that's no longer in any column's list.
        var allInColumns = _kanbanColumns.SelectMany(c => c.Cards).ToHashSet();
        var missing = _allCards.FirstOrDefault(c => !allInColumns.Contains(c));
        if (missing is null) { return; }
        var idx = Math.Clamp(args.NewIndex, 0, targetCol.Cards.Count);
        targetCol.Cards.Insert(idx, missing);
    }

    // ── Clone mode ────────────────────────────────────────────────────────
    private List<BasicItem> _cloneSource =
    [
        new("Template A"), new("Template B"), new("Template C"),
    ];

    private List<BasicItem> _cloneTarget = [];

    // ── Locked items ──────────────────────────────────────────────────────
    private record LockedItem(string Title, bool Locked);

    private List<LockedItem> _lockedItems =
    [
        new("Required: Terms of Service", Locked: true),
        new("Optional: Marketing emails",  Locked: false),
        new("Required: Privacy policy",    Locked: true),
        new("Optional: Newsletter",        Locked: false),
        new("Optional: Product updates",   Locked: false),
    ];

    // ── Shared helper ─────────────────────────────────────────────────────
    private static void SortList<T>(IList<T> list, (int OldIndex, int NewIndex) args)
    {
        var (oldIndex, newIndex) = args;
        if (oldIndex < 0 || oldIndex >= list.Count) { return; }
        var item = list[oldIndex];
        list.RemoveAt(oldIndex);
        if (newIndex < list.Count)
        {
            list.Insert(newIndex, item);
        }
        else
        {
            list.Add(item);
        }
    }
}
