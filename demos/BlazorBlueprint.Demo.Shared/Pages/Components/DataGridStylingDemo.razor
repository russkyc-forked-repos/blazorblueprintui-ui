@page "/components/datagrid-styling"
@using BlazorBlueprint.Demo.Services
@inject MockDataService MockDataService

<PageTitle>DataGrid Styling - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-7xl">
    <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight">DataGrid Styling</h1>
        <p class="text-xl text-muted-foreground">
            Customize cell content, headers, row appearance, and grid styling with Tailwind CSS utilities.
        </p>
    </div>

    <!-- ── Custom Cell Templates ───────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Custom Cell Templates</h2>
            <p class="text-sm text-muted-foreground">
                Use <code class="bg-muted px-1 py-0.5 rounded">BbDataGridTemplateColumn</code> for fully custom cell content,
                or add <code class="bg-muted px-1 py-0.5 rounded">CellTemplate</code> to a PropertyColumn.
            </p>
        </div>
        <BbDataGrid TData="Person" Items="@people" InitialPageSize="5">
            <Columns>
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable>
                    <CellTemplate Context="person">
                        <div class="flex items-center gap-2">
                            <BbAvatar Class="h-8 w-8">
                                <BbAvatarFallback Class="text-xs">@GetInitials(person.Name)</BbAvatarFallback>
                            </BbAvatar>
                            <span class="font-medium">@person.Name</span>
                        </div>
                    </CellTemplate>
                </BbDataGridPropertyColumn>
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Email)" Sortable />
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" Sortable>
                    <CellTemplate Context="person">
                        <BbBadge Variant="@(person.Status == "Active" ? BadgeVariant.Default : person.Status == "Pending" ? BadgeVariant.Secondary : BadgeVariant.Outline)">
                            @person.Status
                        </BbBadge>
                    </CellTemplate>
                </BbDataGridPropertyColumn>
                <BbDataGridTemplateColumn TData="Person" Title="Actions">
                    <ChildContent Context="person">
                        <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small">Edit</BbButton>
                    </ChildContent>
                </BbDataGridTemplateColumn>
            </Columns>
        </BbDataGrid>
        <CodeBlock Source="Components/DataGrid/custom-cell-templates.txt" />
    </div>

    <!-- ── Custom Header Template ──────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Custom Header Template</h2>
            <p class="text-sm text-muted-foreground">
                Use <code class="bg-muted px-1 py-0.5 rounded">HeaderTemplate</code> on a
                <code class="bg-muted px-1 py-0.5 rounded">BbDataGridTemplateColumn</code> to replace
                the default header text with custom content. Sort icons and resize handles are preserved.
            </p>
        </div>
        <BbDataGrid TData="Person" Items="@people" InitialPageSize="5">
            <Columns>
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable />
                <BbDataGridTemplateColumn TData="Person" Title="Contact" Sortable
                    SortBy="@(p => (object)p.Email)">
                    <HeaderTemplate>
                        <div class="flex items-center gap-1.5">
                            <LucideIcon Name="mail" Class="h-4 w-4" />
                            <span>Contact</span>
                        </div>
                    </HeaderTemplate>
                    <ChildContent Context="person">
                        @person.Email
                    </ChildContent>
                </BbDataGridTemplateColumn>
                <BbDataGridTemplateColumn TData="Person" Title="Status" Sortable
                    SortBy="@(p => (object)p.Status)">
                    <HeaderTemplate>
                        <div class="flex items-center gap-1.5">
                            <LucideIcon Name="activity" Class="h-4 w-4" />
                            <span>Status</span>
                        </div>
                    </HeaderTemplate>
                    <ChildContent Context="person">
                        <BbBadge Variant="@(person.Status == "Active" ? BadgeVariant.Default : BadgeVariant.Secondary)">
                            @person.Status
                        </BbBadge>
                    </ChildContent>
                </BbDataGridTemplateColumn>
                <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable />
            </Columns>
        </BbDataGrid>
        <CodeBlock Source="Components/DataGrid/header-template.txt" />
    </div>

    <!-- ── Row & Column Styling ──────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Row & Column Styling</h2>
            <p class="text-sm text-muted-foreground">
                Use <code class="bg-muted px-1 py-0.5 rounded">RowClass</code> to apply CSS classes
                per row based on data, <code class="bg-muted px-1 py-0.5 rounded">CellClass</code> for
                column cell styling, and <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> for
                column header styling.
            </p>
        </div>
        <BbDataGrid TData="Person" Items="@people" InitialPageSize="5"
                   RowClass="@(p => p.Status == "Inactive" ? "opacity-50" : null)">
            <Columns>
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable
                    HeaderClass="text-primary" />
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable
                    CellClass="font-mono tabular-nums" HeaderClass="text-right"  />
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
            </Columns>
        </BbDataGrid>
        <CodeBlock Source="Components/DataGrid/row-column-styling.txt" />
    </div>

    <!-- ── Custom Styling Showcase ────────────────────────────────── -->
    <div class="space-y-8">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Custom Styling Showcase</h2>
            <p class="text-sm text-muted-foreground">
                Combine <code class="bg-muted px-1 py-0.5 rounded">Class</code>,
                <code class="bg-muted px-1 py-0.5 rounded">RowClass</code>,
                <code class="bg-muted px-1 py-0.5 rounded">CellClass</code>, and
                <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> with Tailwind CSS
                utilities for full visual customization of the grid.
            </p>
        </div>

        <!-- Grid Lines -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Grid Lines</h3>
                <p class="text-sm text-muted-foreground">
                    Add visible row and column borders. Apply <code class="bg-muted px-1 py-0.5 rounded">border-r</code>
                    via <code class="bg-muted px-1 py-0.5 rounded">CellClass</code> and
                    <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> on each column,
                    and wrap the grid in an outer border with <code class="bg-muted px-1 py-0.5 rounded">Class</code>.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5"
                       Class="border border-border rounded-lg overflow-hidden">
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable
                        CellClass="border-r border-border/40" HeaderClass="border-r border-border/40" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable
                        CellClass="border-r border-border/40" HeaderClass="border-r border-border/40" />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable
                        CellClass="border-r border-border/40" HeaderClass="border-r border-border/40" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-grid-lines.txt" />
        </div>

        <!-- Striped Rows (Built-in) -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Striped Rows</h3>
                <p class="text-sm text-muted-foreground">
                    Use the built-in <code class="bg-muted px-1 py-0.5 rounded">Striped</code> parameter
                    for alternating row backgrounds. Customize the stripe appearance with
                    <code class="bg-muted px-1 py-0.5 rounded">StripeClass</code> (defaults to
                    <code class="bg-muted px-1 py-0.5 rounded">even:bg-muted/30 even:hover:bg-muted/70</code>).
                    Composes with <code class="bg-muted px-1 py-0.5 rounded">RowClass</code>.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5" Striped>
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-striped-rows.txt" />
        </div>

        <!-- Table Container Styling -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Table Container Styling</h3>
                <p class="text-sm text-muted-foreground">
                    Use <code class="bg-muted px-1 py-0.5 rounded">TableContainerClass</code> to style
                    the inner scrollable container that wraps the table. Useful for adding borders,
                    rounded corners, or constraining height.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5"
                       TableContainerClass="rounded-xl border-2 border-primary/20">
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-table-container.txt" />
        </div>

        <!-- Striped Columns -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Striped Columns</h3>
                <p class="text-sm text-muted-foreground">
                    Apply <code class="bg-muted px-1 py-0.5 rounded">CellClass</code> and
                    <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> to alternating
                    columns for a vertical stripe effect.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5">
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable
                        CellClass="bg-muted" HeaderClass="bg-muted" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable
                        CellClass="bg-muted" HeaderClass="bg-muted" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-striped-columns.txt" />
        </div>

        <!-- Colored Header -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Colored Header</h3>
                <p class="text-sm text-muted-foreground">
                    Apply a distinct background colour to the header row using
                    <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> on each column.
                    TailwindMerge automatically resolves conflicting classes with the base header styles.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5">
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable
                        HeaderClass="bg-primary text-primary-foreground" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable
                        HeaderClass="bg-primary text-primary-foreground" />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable
                        HeaderClass="bg-primary text-primary-foreground" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)"
                        HeaderClass="bg-primary text-primary-foreground" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-colored-header.txt" />
        </div>
    </div>

    <!-- ── Empty & Loading States ──────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Empty & Loading States</h2>
            <p class="text-sm text-muted-foreground">
                The grid shows an empty state when there is no data, and a loading state when
                <code class="bg-muted px-1 py-0.5 rounded">IsLoading</code> is true.
            </p>
        </div>
        <div class="flex gap-4">
            <BbButton OnClick="ToggleLoading" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                Toggle Loading
            </BbButton>
        </div>
        <BbDataGrid TData="Person" Items="@(Array.Empty<Person>())" IsLoading="@_isLoading">
            <Columns>
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" />
                <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Email)" />
            </Columns>
        </BbDataGrid>
        <CodeBlock Source="Components/DataGrid/empty-loading.txt" />
    </div>
</div>

@code {
    private List<Person> people = new();
    private bool _isLoading;

    protected override void OnInitialized()
    {
        people = MockDataService.GeneratePersons(50);
    }

    private void ToggleLoading() => _isLoading = !_isLoading;

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : parts.Length == 1 ? $"{parts[0][0]}" : "?";
    }
}
