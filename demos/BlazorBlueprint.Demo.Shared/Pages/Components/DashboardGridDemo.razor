@page "/components/dashboard-grid"
@using System.Text.Json

<PageTitle>Dashboard Grid - Blazor Blueprint</PageTitle>

<style>
    .styled-widget-dark {
        background-color: #18181b !important;
        border-color: rgba(63, 63, 70, 0.5) !important;
        color: #fff !important;
    }
    .styled-header-gradient {
        background: linear-gradient(to right, #2563eb, #06b6d4) !important;
        border-color: rgba(63, 63, 70, 0.5) !important;
        color: #fff !important;
    }
    .styled-widget-warm {
        --styled-accent: #ea580c;
        background-color: rgba(255, 247, 237, 0.5) !important;
        border-color: rgba(253, 186, 116, 0.4) !important;
    }
    .styled-header-warm {
        border-color: rgba(253, 186, 116, 0.4) !important;
    }
    .styled-widget-cool {
        --styled-accent: #0d9488;
        background-color: rgba(240, 253, 250, 0.5) !important;
        border-color: rgba(153, 246, 228, 0.4) !important;
    }
    .styled-header-cool {
        border-color: rgba(153, 246, 228, 0.4) !important;
    }
    .dark .styled-widget-warm {
        --styled-accent: #fb923c;
        background-color: rgba(124, 45, 18, 0.15) !important;
        border-color: rgba(154, 52, 18, 0.25) !important;
    }
    .dark .styled-header-warm {
        border-color: rgba(154, 52, 18, 0.25) !important;
    }
    .dark .styled-widget-cool {
        --styled-accent: #2dd4bf;
        background-color: rgba(4, 47, 46, 0.25) !important;
        border-color: rgba(17, 94, 89, 0.25) !important;
    }
    .dark .styled-header-cool {
        border-color: rgba(17, 94, 89, 0.25) !important;
    }
</style>

<div class="space-y-8 max-w-7xl">
    <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight">Dashboard Grid</h1>
        <p class="text-xl text-muted-foreground">
            A drag-and-drop, resizable widget layout for composing dashboards. Built on CSS Grid
            with responsive breakpoints, state persistence, and full keyboard accessibility.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl">
            Place widgets with <code class="bg-muted px-1 py-0.5 rounded">BbDashboardWidget</code> inside a
            <code class="bg-muted px-1 py-0.5 rounded">BbDashboardGrid</code>. Widgets can be dragged to reorder
            and resized by their handles. Use <code class="bg-muted px-1 py-0.5 rounded">@@bind-State</code> with
            <code class="bg-muted px-1 py-0.5 rounded">Save()</code> /
            <code class="bg-muted px-1 py-0.5 rounded">Restore()</code> to persist layouts across sessions.
            The grid automatically adapts to responsive breakpoints.
        </p>
    </div>

    <!-- ── Basic Static Dashboard ──────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Basic Static Dashboard</h2>
            <p class="text-sm text-muted-foreground">
                A simple grid with statically placed widgets. Set
                <code class="bg-muted px-1 py-0.5 rounded">Editable="false"</code> to disable drag and resize.
            </p>
        </div>
        <BbDashboardGrid Editable="false">
            <BbDashboardWidget Id="static-1" Column="1" Row="1" ColumnSpan="8" RowSpan="6" Title="Revenue">
                <div class="flex flex-col items-center justify-center h-full">
                    <span class="text-3xl font-bold">$48,250</span>
                    <span class="text-sm text-muted-foreground">+12.5% from last month</span>
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="static-2" Column="9" Row="1" ColumnSpan="8" RowSpan="6" Title="Users">
                <div class="flex flex-col items-center justify-center h-full">
                    <span class="text-3xl font-bold">2,420</span>
                    <span class="text-sm text-muted-foreground">+8.1% from last month</span>
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="static-3" Column="17" Row="1" ColumnSpan="8" RowSpan="6" Title="Orders">
                <div class="flex flex-col items-center justify-center h-full">
                    <span class="text-3xl font-bold">1,210</span>
                    <span class="text-sm text-muted-foreground">+3.2% from last month</span>
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="static-4" Column="1" Row="7" ColumnSpan="16" RowSpan="8" Title="Sales Overview">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    Chart placeholder — use BbAreaChart or BbBarChart here
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="static-5" Column="17" Row="7" ColumnSpan="8" RowSpan="8" Title="Recent Activity">
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between"><span>New signup</span><span class="text-muted-foreground">2m ago</span></div>
                    <div class="flex justify-between"><span>Order placed</span><span class="text-muted-foreground">5m ago</span></div>
                    <div class="flex justify-between"><span>Payment received</span><span class="text-muted-foreground">12m ago</span></div>
                    <div class="flex justify-between"><span>User upgraded</span><span class="text-muted-foreground">1h ago</span></div>
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/basic-static.txt" />
    </div>

    <!-- ── Editable (Drag + Resize) ───────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Editable (Drag + Resize)</h2>
            <p class="text-sm text-muted-foreground">
                Hover over a widget to reveal the drag handle (grip icon in the header) and resize handles (corners and edges).
                Drag to reorder, resize by pulling the handles.
            </p>
        </div>
        <BbDashboardGrid @bind-State="editableState">
            @foreach (var widget in editableWidgets)
            {
                <BbDashboardWidget @key="widget.Id" Id="@widget.Id" Column="@widget.Column" Row="@widget.Row"
                                  ColumnSpan="@widget.ColSpan" RowSpan="@widget.RowSpan" Title="@widget.Title"
                                  OnRemove="RemoveEditableWidget">
                    <div class="flex items-center justify-center h-full text-muted-foreground">
                        @widget.Description
                    </div>
                </BbDashboardWidget>
            }
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/editable.txt" />
    </div>

    <!-- ── Responsive Breakpoints ──────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Responsive Breakpoints</h2>
            <p class="text-sm text-muted-foreground">
                The grid automatically adjusts columns at different viewport widths.
                <code class="bg-muted px-1 py-0.5 rounded">MediumColumns="12"</code> at 1024px,
                <code class="bg-muted px-1 py-0.5 rounded">SmallColumns="2"</code> at 768px.
                Resize your browser to see the layout adapt.
            </p>
        </div>
        <BbDashboardGrid Columns="24" RowHeight="30" Gap="6"
                         MediumColumns="12" SmallColumns="4"
                         MediumBreakpoint="1024" SmallBreakpoint="768"
                         Editable="false"
                         OnBreakpointChanged="HandleBreakpointChanged">
            <BbDashboardWidget Id="resp-1" Column="1" Row="1" ColumnSpan="6" RowSpan="4" Title="Metric 1">
                <div class="flex items-center justify-center h-full font-bold text-2xl">42</div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="resp-2" Column="7" Row="1" ColumnSpan="6" RowSpan="4" Title="Metric 2">
                <div class="flex items-center justify-center h-full font-bold text-2xl">87</div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="resp-3" Column="13" Row="1" ColumnSpan="6" RowSpan="4" Title="Metric 3">
                <div class="flex items-center justify-center h-full font-bold text-2xl">156</div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="resp-4" Column="19" Row="1" ColumnSpan="6" RowSpan="4" Title="Metric 4">
                <div class="flex items-center justify-center h-full font-bold text-2xl">73</div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        @if (currentBreakpoint != null)
        {
            <p class="text-sm text-muted-foreground">
                Current breakpoint: <BbBadge>@currentBreakpoint</BbBadge>
            </p>
        }
        <CodeBlock Source="Components/DashboardGrid/responsive.txt" />
    </div>

    <!-- ── Toggle Edit Mode ────────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Toggle Edit Mode</h2>
            <p class="text-sm text-muted-foreground">
                Use the <code class="bg-muted px-1 py-0.5 rounded">Editable</code> parameter to toggle
                drag and resize at runtime. Click the button to switch modes.
            </p>
        </div>
        <BbButton OnClick="() => isEditable = !isEditable" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
            @(isEditable ? "Lock Dashboard" : "Edit Dashboard")
        </BbButton>
        <BbDashboardGrid Editable="@isEditable">
            <BbDashboardWidget Id="toggle-1" Column="1" Row="1" ColumnSpan="12" RowSpan="6" Title="Editable Widget">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    @(isEditable ? "Drag handles visible on hover" : "Editing disabled")
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="toggle-2" Column="13" Row="1" ColumnSpan="12" RowSpan="6" Title="Another Widget">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    @(isEditable ? "Resize handles visible on hover" : "Editing disabled")
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/toggle-edit.txt" />
    </div>

    <!-- ── Freeform Layout ─────────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Freeform Layout</h2>
            <p class="text-sm text-muted-foreground">
                Set <code class="bg-muted px-1 py-0.5 rounded">Compact="false"</code> to disable automatic compaction.
                Widgets stay exactly where you place them — no snapping to fill gaps. Toggle it at runtime to switch
                between freeform and compact modes.
            </p>
        </div>
        <BbButton OnClick="() => isFreeformCompact = !isFreeformCompact" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
            @(isFreeformCompact ? "Switch to Freeform" : "Switch to Compact")
        </BbButton>
        <BbDashboardGrid Compact="@isFreeformCompact" Border="true">
            <BbDashboardWidget Id="freeform-1" Column="1" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget A">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    @(isFreeformCompact ? "Compact — widgets snap together" : "Freeform — place anywhere")
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="freeform-2" Column="1" Row="9" ColumnSpan="8" RowSpan="6" Title="Widget B">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    Try moving me with arrow keys
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="freeform-3" Column="17" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget C">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    Gaps are preserved in freeform mode
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/freeform.txt" />
    </div>

    <!-- ── Fixed Cell Size ────────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Fixed Cell Size</h2>
            <p class="text-sm text-muted-foreground">
                Set <code class="bg-muted px-1 py-0.5 rounded">CellWidth</code> to create a strict grid with fixed-size
                square cells. Use <code class="bg-muted px-1 py-0.5 rounded">MaxWidth</code> to constrain the container
                and enable horizontal scrolling when the grid exceeds it.
            </p>
        </div>
        <BbDashboardGrid @bind-State="fixedCellState" Columns="24" RowHeight="40" CellWidth="40" Gap="8" MaxWidth="800" Border="true">
            <BbDashboardWidget Id="fixed-1" Column="1" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget A">
                <div class="flex items-center justify-center h-full text-muted-foreground text-sm">
                    8 × 6 cells
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="fixed-2" Column="9" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget B">
                <div class="flex items-center justify-center h-full text-muted-foreground text-sm">
                    8 × 6 cells
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="fixed-3" Column="17" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget C">
                <div class="flex items-center justify-center h-full text-muted-foreground text-sm">
                    8 × 6 cells
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
    </div>

    <!-- ── State Persistence ───────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">State Persistence</h2>
            <p class="text-sm text-muted-foreground">
                Use <code class="bg-muted px-1 py-0.5 rounded">Save()</code> and
                <code class="bg-muted px-1 py-0.5 rounded">Restore()</code> to serialize and restore
                the grid layout. The state can be persisted to localStorage, a database, or any other storage.
            </p>
        </div>
        <div class="flex gap-2">
            <BbButton OnClick="SaveState" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">Save Layout</BbButton>
            <BbButton OnClick="RestoreState" Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Disabled="@(savedSnapshot == null)">Restore Layout</BbButton>
            <BbButton OnClick="ResetState" Variant="ButtonVariant.Destructive" Size="ButtonSize.Small">Reset</BbButton>
        </div>
        <BbDashboardGrid @bind-State="persistState">
            <BbDashboardWidget Id="persist-1" Column="1" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget 1">
                <div class="flex items-center justify-center h-full text-muted-foreground">Drag and resize, then save</div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="persist-2" Column="9" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget 2">
                <div class="flex items-center justify-center h-full text-muted-foreground">Move me around</div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="persist-3" Column="17" Row="1" ColumnSpan="8" RowSpan="6" Title="Widget 3">
                <div class="flex items-center justify-center h-full text-muted-foreground">Then restore</div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        @if (savedSnapshot != null)
        {
            <pre class="text-xs bg-muted p-3 rounded-lg overflow-auto max-h-40">@JsonSerializer.Serialize(savedSnapshot, jsonOptions)</pre>
        }
        <CodeBlock Source="Components/DashboardGrid/state-persistence.txt" />
    </div>

    <!-- ── Custom Widget Content ───────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Custom Widget Content</h2>
            <p class="text-sm text-muted-foreground">
                Widgets can contain any Blazor content — charts, tables, forms, or custom components.
                Use the <code class="bg-muted px-1 py-0.5 rounded">Header</code>,
                <code class="bg-muted px-1 py-0.5 rounded">ChildContent</code>, and
                <code class="bg-muted px-1 py-0.5 rounded">Footer</code> render fragments.
            </p>
        </div>
        <BbDashboardGrid Editable="false">
            <BbDashboardWidget Id="custom-1" Column="1" Row="1" ColumnSpan="8" RowSpan="8" Title="Progress Metrics">
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-sm mb-1"><span>CPU Usage</span><span>72%</span></div>
                        <BbProgress Value="72" />
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1"><span>Memory</span><span>58%</span></div>
                        <BbProgress Value="58" />
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1"><span>Disk</span><span>34%</span></div>
                        <BbProgress Value="34" />
                    </div>
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="custom-2" Column="9" Row="1" ColumnSpan="8" RowSpan="8">
                <Header>
                    <BbDashboardWidgetHeader>
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-semibold">Custom Header</span>
                            <BbBadge Variant="BadgeVariant.Secondary">Live</BbBadge>
                        </div>
                    </BbDashboardWidgetHeader>
                </Header>
                <ChildContent>
                    <div class="flex items-center justify-center h-full text-muted-foreground">
                        Widget with custom header and badge
                    </div>
                </ChildContent>
            </BbDashboardWidget>
            <BbDashboardWidget Id="custom-3" Column="17" Row="1" ColumnSpan="8" RowSpan="8" Title="With Footer">
                <ChildContent>
                    <div class="flex items-center justify-center h-full text-muted-foreground">
                        This widget has a footer
                    </div>
                </ChildContent>
                <Footer>
                    <div class="flex justify-end">
                        <BbButton Variant="ButtonVariant.Link" Size="ButtonSize.Small">View Details</BbButton>
                    </div>
                </Footer>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/custom-content.txt" />
    </div>

    <!-- ── Constrained Widgets ─────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Constrained Widgets</h2>
            <p class="text-sm text-muted-foreground">
                Widgets support <code class="bg-muted px-1 py-0.5 rounded">MinColumnSpan</code>,
                <code class="bg-muted px-1 py-0.5 rounded">MaxColumnSpan</code>, and
                <code class="bg-muted px-1 py-0.5 rounded">Static</code> to control resizing limits
                and lock widgets in place.
            </p>
        </div>
        <BbDashboardGrid>
            <BbDashboardWidget Id="constrained-1" Column="1" Row="1" ColumnSpan="8" RowSpan="4"
                              MinColumnSpan="6" MaxColumnSpan="12" MinRowSpan="4" MaxRowSpan="8"
                              Title="Constrained (6-12 cols, 4-8 rows)">
                <div class="flex items-center justify-center h-full text-sm text-muted-foreground">
                    Resize is clamped to min/max
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="constrained-2" Column="9" Row="1" ColumnSpan="8" RowSpan="4"
                              Static="true" Title="Static (locked)">
                <div class="flex items-center justify-center h-full text-sm text-muted-foreground">
                    Cannot be dragged or resized
                </div>
            </BbDashboardWidget>
            <BbDashboardWidget Id="constrained-3" Column="17" Row="1" ColumnSpan="8" RowSpan="4"
                              Draggable="false" Title="No Drag (resize only)">
                <div class="flex items-center justify-center h-full text-sm text-muted-foreground">
                    Resize allowed, drag disabled
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/constrained.txt" />
    </div>

    <!-- ── Border & Background ─────────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Border & Background</h2>
            <p class="text-sm text-muted-foreground">
                Add a container border with <code class="bg-muted px-1 py-0.5 rounded">Border="true"</code> and
                choose a background pattern with <code class="bg-muted px-1 py-0.5 rounded">Background</code>:
                <code class="bg-muted px-1 py-0.5 rounded">None</code> or
                <code class="bg-muted px-1 py-0.5 rounded">Grid</code>.
                Drag and resize the widgets to see the background pattern behind them.
            </p>
        </div>
        <div class="space-y-6">
            <div class="space-y-2">
                <p class="text-sm font-medium">No background (with border)</p>
                <BbDashboardGrid Border="true" Background="DashboardBackground.None">
                    <BbDashboardWidget Id="bg-none-1" Column="1" Row="1" ColumnSpan="8" RowSpan="6" Title="Revenue">
                        <div class="flex flex-col items-center justify-center h-full">
                            <span class="text-3xl font-bold">$48,250</span>
                            <span class="text-sm text-muted-foreground">+12.5% from last month</span>
                        </div>
                    </BbDashboardWidget>
                    <BbDashboardWidget Id="bg-none-2" Column="9" Row="1" ColumnSpan="8" RowSpan="6" Title="Active Users">
                        <div class="flex flex-col items-center justify-center h-full">
                            <span class="text-3xl font-bold">2,420</span>
                            <span class="text-sm text-muted-foreground">+8.1% from last month</span>
                        </div>
                    </BbDashboardWidget>
                    <BbDashboardWidget Id="bg-none-3" Column="17" Row="1" ColumnSpan="8" RowSpan="6" Title="Conversion">
                        <div class="flex flex-col items-center justify-center h-full">
                            <span class="text-3xl font-bold">3.2%</span>
                            <span class="text-sm text-muted-foreground">+0.4% from last month</span>
                        </div>
                    </BbDashboardWidget>
                </BbDashboardGrid>
            </div>
            <div class="space-y-2">
                <p class="text-sm font-medium">Grid background (with border)</p>
                <BbDashboardGrid Border="true" Background="DashboardBackground.Grid">
                    <BbDashboardWidget Id="bg-squares-1" Column="1" Row="1" ColumnSpan="12" RowSpan="6" Title="Sales Chart">
                        <div class="flex items-center justify-center h-full text-muted-foreground">
                            Drag me around — Grid cells show widget snap positions
                        </div>
                    </BbDashboardWidget>
                    <BbDashboardWidget Id="bg-squares-2" Column="13" Row="1" ColumnSpan="12" RowSpan="6" Title="User Growth">
                        <div class="flex items-center justify-center h-full text-muted-foreground">
                            Resize from the bottom-right corner
                        </div>
                    </BbDashboardWidget>
                </BbDashboardGrid>
            </div>
        </div>
        <CodeBlock Source="Components/DashboardGrid/border-background.txt" />
    </div>

    <!-- ── Fixed Height Container ─────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Fixed Height Container</h2>
            <p class="text-sm text-muted-foreground">
                Use <code class="bg-muted px-1 py-0.5 rounded">MaxRows</code> to define a fixed grid height.
                This example has an 8-row grid with a single widget occupying the top-left quarter.
                Drag the widget around the container or resize it to fill more space.
            </p>
        </div>
        <BbDashboardGrid MaxRows="8" Border="true" Background="DashboardBackground.Grid">
            <BbDashboardWidget Id="fixed-1" Column="1" Row="1" ColumnSpan="12" RowSpan="4" Title="Top-Left Quarter">
                <div class="flex items-center justify-center h-full text-muted-foreground">
                    1/4 of the container — drag or resize me
                </div>
            </BbDashboardWidget>
        </BbDashboardGrid>
        <CodeBlock Source="Components/DashboardGrid/fixed-height.txt" />
    </div>

    <!-- ── Add / Remove Widgets ───────────────────────────────────── -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Add / Remove Widgets</h2>
            <p class="text-sm text-muted-foreground">
                Widgets are standard Blazor child components — add and remove them dynamically using
