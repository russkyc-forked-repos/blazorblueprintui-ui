    private class DataDrivenWidgetConfig
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string DataSource { get; set; } = string.Empty;
        public int Column { get; set; } = 1;
        public int Row { get; set; } = 1;
        public int ColSpan { get; set; } = 4;
        public int RowSpan { get; set; } = 3;
    }

    private class DataDrivenTimeSeriesPoint
    {
        public string Month { get; set; } = "";
        public int Value { get; set; }
    }

    private class DataDrivenCategoryPoint
    {
        public string Name { get; set; } = "";
        public int Value { get; set; }
        public string Fill { get; set; } = "";
    }

    private class DataDrivenKpiData
    {
        public string Value { get; set; } = "";
        public string Label { get; set; } = "";
        public string? Change { get; set; }
    }

    private class DataDrivenTableRow
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
        public string Change { get; set; } = "";
        public bool IsPositive { get; set; }
    }

