    @* --- API Reference --- *@
    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">API Reference</h2>
            <p class="text-muted-foreground">Component properties and parameters.</p>
        </div>
        <div class="space-y-4">
            <ApiReference ComponentName="BbDashboardGrid">
                <ApiParameter Name="Columns" Type="int" Default="24">
                    Number of columns in the grid layout.
                </ApiParameter>
                <ApiParameter Name="RowHeight" Type="int" Default="40">
                    Height of each grid row in pixels.
                </ApiParameter>
                <ApiParameter Name="Gap" Type="int" Default="8">
                    Gap between grid cells in pixels.
                </ApiParameter>
                <ApiParameter Name="MaxRows" Type="int" Default="0">
                    Maximum number of rows. <code>0</code> means auto (unlimited).
                </ApiParameter>
                <ApiParameter Name="State" Type="DashboardGridState?" Default="null">
                    Controlled state object for two-way binding via <code>@@bind-State</code>.
                </ApiParameter>
                <ApiParameter Name="AllowDrag" Type="bool" Default="true">
                    Whether widget dragging is enabled.
                </ApiParameter>
                <ApiParameter Name="AllowResize" Type="bool" Default="true">
                    Whether widget resizing is enabled.
                </ApiParameter>
                <ApiParameter Name="Editable" Type="bool" Default="true">
                    Master toggle for edit mode. When <code>false</code>, disables both drag and resize.
                </ApiParameter>
                <ApiParameter Name="Compact" Type="bool" Default="true">
                    Automatically compact widgets toward the top-left to fill gaps after drag, resize, or removal. Set to <code>false</code> for a freeform layout where widgets stay exactly where placed.
                </ApiParameter>
                <ApiParameter Name="ShowGridGuide" Type="bool" Default="true">
                    Show a dashed grid overlay during drag operations.
                </ApiParameter>
                <ApiParameter Name="Border" Type="bool" Default="false">
                    Add a rounded border around the grid container.
                </ApiParameter>
                <ApiParameter Name="Background" Type="DashboardBackground" Default="Grid">
                    Background pattern shown when the grid is in edit mode: <code>None</code> or <code>Grid</code>. Automatically hidden when <code>Editable</code> is <code>false</code>.
                </ApiParameter>
                <ApiParameter Name="Loading" Type="bool" Default="false">
                    When <code>true</code>, displays a skeleton loading state instead of the grid.
                </ApiParameter>
                <ApiParameter Name="LoadingContent" Type="RenderFragment?" Default="null">
                    Custom loading content. Overrides the default skeleton layout when <code>Loading</code> is <code>true</code>.
                </ApiParameter>
                <ApiParameter Name="EmptyContent" Type="RenderFragment?" Default="null">
                    Custom empty state content. Overrides the default empty state when there are no widgets.
                </ApiParameter>
                <ApiParameter Name="OnAddWidget" Type="EventCallback" Default="">
                    Callback for the "Add Widget" button in the default empty state.
                </ApiParameter>
                <ApiParameter Name="MediumColumns" Type="int" Default="12">
                    Number of columns at the medium breakpoint.
                </ApiParameter>
                <ApiParameter Name="SmallColumns" Type="int" Default="2">
                    Number of columns at the small breakpoint.
                </ApiParameter>
                <ApiParameter Name="MediumBreakpoint" Type="int" Default="1024">
                    Viewport width threshold for medium breakpoint in pixels.
                </ApiParameter>
                <ApiParameter Name="SmallBreakpoint" Type="int" Default="768">
                    Viewport width threshold for small breakpoint in pixels.
                </ApiParameter>
                <ApiParameter Name="OnWidgetDragEnd" Type="EventCallback&lt;WidgetDragEventArgs&gt;">
                    Callback fired when a widget drag operation completes.
                </ApiParameter>
                <ApiParameter Name="OnWidgetResizeEnd" Type="EventCallback&lt;WidgetResizeEventArgs&gt;">
                    Callback fired when a widget resize operation completes.
                </ApiParameter>
                <ApiParameter Name="OnLayoutChanged" Type="EventCallback&lt;DashboardGridLayout&gt;">
                    Callback fired when the layout changes (after drag or resize).
                </ApiParameter>
                <ApiParameter Name="OnBreakpointChanged" Type="EventCallback&lt;DashboardBreakpoint&gt;">
                    Callback fired when the responsive breakpoint changes.
                </ApiParameter>
                <ApiParameter Name="AriaLabel" Type="string?" Default="null">
                    Accessible label for the grid region.
                </ApiParameter>
                <ApiParameter Name="ChildContent" Type="RenderFragment?" Default="null">
                    The <code>BbDashboardWidget</code> components to render inside the grid.
                </ApiParameter>
                <ApiParameter Name="Class" Type="string?" Default="null">
                    Additional CSS classes for the grid container.
                </ApiParameter>
            </ApiReference>

            <ApiReference ComponentName="BbDashboardWidget">
                <ApiParameter Name="Id" Type="string" Default="(required)">
                    Unique identifier for the widget.
                </ApiParameter>
                <ApiParameter Name="Column" Type="int" Default="1">
                    Starting column position (1-based).
                </ApiParameter>
                <ApiParameter Name="Row" Type="int" Default="1">
                    Starting row position (1-based).
                </ApiParameter>
                <ApiParameter Name="ColumnSpan" Type="int" Default="1">
                    Number of columns the widget spans.
                </ApiParameter>
                <ApiParameter Name="RowSpan" Type="int" Default="1">
                    Number of rows the widget spans.
                </ApiParameter>
                <ApiParameter Name="MinColumnSpan" Type="int" Default="4">
                    Minimum column span when resizing.
                </ApiParameter>
                <ApiParameter Name="MinRowSpan" Type="int" Default="4">
                    Minimum row span when resizing.
                </ApiParameter>
                <ApiParameter Name="MaxColumnSpan" Type="int" Default="0">
                    Maximum column span when resizing. <code>0</code> means grid max.
                </ApiParameter>
                <ApiParameter Name="MaxRowSpan" Type="int" Default="0">
                    Maximum row span when resizing. <code>0</code> means unlimited.
                </ApiParameter>
                <ApiParameter Name="Draggable" Type="bool" Default="true">
                    Whether this widget can be dragged.
                </ApiParameter>
                <ApiParameter Name="Resizable" Type="bool" Default="true">
                    Whether this widget can be resized.
                </ApiParameter>
                <ApiParameter Name="Static" Type="bool" Default="false">
                    When true, the widget cannot be moved or resized.
                </ApiParameter>
                <ApiParameter Name="Title" Type="string?" Default="null">
                    Header title text. Renders a default header with drag handle.
                </ApiParameter>
                <ApiParameter Name="Header" Type="RenderFragment?" Default="null">
                    Custom header content. Overrides <code>Title</code> when provided.
                </ApiParameter>
                <ApiParameter Name="Footer" Type="RenderFragment?" Default="null">
                    Optional footer content rendered at the bottom of the widget.
                </ApiParameter>
                <ApiParameter Name="Loading" Type="bool" Default="false">
                    When <code>true</code>, displays a loading skeleton inside the widget content area.
                </ApiParameter>
                <ApiParameter Name="LoadingContent" Type="RenderFragment?" Default="null">
                    Custom loading content for the widget. Overrides the default skeleton.
                </ApiParameter>
                <ApiParameter Name="OnRemove" Type="EventCallback&lt;string&gt;">
                    Callback fired when the remove button is clicked. Passes the widget <code>Id</code>. The remove button is only visible in edit mode.
                </ApiParameter>
                <ApiParameter Name="ChildContent" Type="RenderFragment?" Default="null">
                    The main content rendered inside the widget body.
                </ApiParameter>
                <ApiParameter Name="Class" Type="string?" Default="null">
                    Additional CSS classes for the widget card.
                </ApiParameter>
            </ApiReference>

            <ApiReference ComponentName="BbDashboardWidgetHeader">
                <ApiParameter Name="ChildContent" Type="RenderFragment?" Default="null">
                    Header content displayed next to the drag handle.
                </ApiParameter>
                <ApiParameter Name="Class" Type="string?" Default="null">
                    Additional CSS classes for the header.
                </ApiParameter>
            </ApiReference>

            <ApiReference ComponentName="BbDashboardWidgetContent">
                <ApiParameter Name="ChildContent" Type="RenderFragment?" Default="null">
                    Content to display in the widget body area.
                </ApiParameter>
                <ApiParameter Name="Class" Type="string?" Default="null">
                    Additional CSS classes for the content area.
                </ApiParameter>
            </ApiReference>
        </div>
    </section>
</div>

@code {
    // Editable state
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState editableState = new();
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState customStyleState = new();
    private bool customStyleEditable = true;
    private List<DynamicWidget> editableWidgets = new()
    {
        new() { Id = "edit-1", Title = "Widget A", Description = "Drag me or resize from the bottom-right corner", Column = 1, Row = 1, ColSpan = 12, RowSpan = 6 },
        new() { Id = "edit-2", Title = "Widget B", Description = "I can also be dragged and resized", Column = 13, Row = 1, ColSpan = 12, RowSpan = 6 },
        new() { Id = "edit-3", Title = "Widget C", Description = "Small widget", Column = 1, Row = 7, ColSpan = 8, RowSpan = 6 },
        new() { Id = "edit-4", Title = "Widget D", Description = "Wide widget", Column = 9, Row = 7, ColSpan = 16, RowSpan = 6 },
    };

    // Toggle edit mode
    private bool isEditable = true;

    // Freeform layout
    private bool isFreeformCompact = true;

    // Fixed cell size
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState fixedCellState = new();

    // Responsive breakpoint
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardBreakpoint? currentBreakpoint;

    // State persistence
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState persistState = new();
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridStateSnapshot? savedSnapshot;
    private static readonly JsonSerializerOptions jsonOptions = new() { WriteIndented = true };

    // Dynamic widgets
    private List<DynamicWidget> dynamicWidgets = new();
    private int nextWidgetId = 1;

    private void HandleBreakpointChanged(BlazorBlueprint.Primitives.DashboardGrid.DashboardBreakpoint bp) =>
        currentBreakpoint = bp;

    private void SaveState()
    {
        savedSnapshot = persistState.Save();
        StateHasChanged();
    }

    private void RestoreState()
    {
        if (savedSnapshot != null)
        {
            persistState.Restore(savedSnapshot);
            StateHasChanged();
        }
    }

    private void ResetState()
    {
        persistState.Reset();
        savedSnapshot = null;
        StateHasChanged();
    }

    private void AddWidget()
    {
        var id = nextWidgetId++;
        var index = dynamicWidgets.Count;
        var col = (index % 3) * 8 + 1;
        var row = (index / 3) * 6 + 1;

        dynamicWidgets.Add(new DynamicWidget
        {
            Id = $"dynamic-{id}",
            Title = $"Widget {id}",
            Column = col,
            Row = row,
            ColSpan = 8,
            RowSpan = 6
        });
    }

    private void RemoveEditableWidget(string widgetId) =>
        editableWidgets.RemoveAll(w => w.Id == widgetId);

    private void RemoveDynamicWidget(string widgetId) =>
        dynamicWidgets.RemoveAll(w => w.Id == widgetId);

    private void RemoveWidget(string widgetId) =>
        dynamicWidgets.RemoveAll(w => w.Id == widgetId);

    private void RemoveLastWidget()
    {
        if (dynamicWidgets.Count > 0)
        {
            dynamicWidgets.RemoveAt(dynamicWidgets.Count - 1);
        }
    }

    private class DynamicWidget
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Column { get; set; } = 1;
        public int Row { get; set; } = 1;
        public int ColSpan { get; set; } = 8;
        public int RowSpan { get; set; } = 6;
    }

    // ── Data-Driven Dashboard ──

    private BbDashboardGrid? dataDrivenGridRef;
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState dataDrivenGridState = new();
    private List<DataDrivenWidgetConfig> dataDrivenWidgets = new();
    private bool dataDrivenLoaded;
    private bool dataDrivenLoading;
    private string? dataDrivenSavedJson;

    private async Task LoadDataDrivenDashboard()
    {
        dataDrivenLoading = true;
        StateHasChanged();

        await Task.Delay(800);

        var payload = JsonSerializer.Deserialize<DataDrivenPayload>(SampleDataDrivenJson, dataDrivenJsonOptions)!;
        dataDrivenWidgets = payload.Widgets;

        dataDrivenGridState = new BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState();
        foreach (var w in dataDrivenWidgets)
        {
            dataDrivenGridState.RegisterWidget(w.Id, w.Column, w.Row, w.ColSpan, w.RowSpan);
        }

        dataDrivenLoaded = true;
        dataDrivenLoading = false;
        dataDrivenSavedJson = null;
    }

    private void UnloadDataDrivenDashboard()
    {
        dataDrivenWidgets.Clear();
        dataDrivenGridState = new BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState();
        dataDrivenLoaded = false;
        dataDrivenSavedJson = null;
    }

    private void SaveDataDrivenDashboard()
    {
        var config = dataDrivenGridRef?.GetConfig();
        dataDrivenSavedJson = config != null ? JsonSerializer.Serialize(config, dataDrivenJsonOptions) : null;
    }

    private void RemoveDataDrivenWidget(string widgetId)
    {
        dataDrivenWidgets.RemoveAll(w => w.Id == widgetId);
    }

    private RenderFragment RenderDataDrivenWidgetContent(DataDrivenWidgetConfig widget) => widget.Type switch
    {
        "bar-chart" => __builder =>
        {
            <BbBarChart Data="@GetDataDrivenTimeSeries(widget)" Height="100%">
                <BbXAxis DataKey="month" />
                <BbYAxis Show="false" />
                <BbChartTooltip />
                <BbBar DataKey="value" Name="@widget.Title" Color="var(--chart-1)" />
            </BbBarChart>
        },
        "area-chart" => __builder =>
        {
            <BbAreaChart Data="@GetDataDrivenTimeSeries(widget)" Height="100%">
                <BbXAxis DataKey="month" />
                <BbYAxis Show="false" />
                <BbChartTooltip />
                <BbArea DataKey="value" Name="@widget.Title" Color="var(--chart-2)" Curve="CurveType.Smooth">
                    <BbFill>
                        <BbLinearGradient>
                            <BbGradientStop Offset="0" Color="var(--chart-2)" Opacity="0.5" />
                            <BbGradientStop Offset="1" Color="var(--chart-2)" Opacity="0.05" />
                        </BbLinearGradient>
                    </BbFill>
                </BbArea>
            </BbAreaChart>
        },
        "line-chart" => __builder =>
        {
            <BbLineChart Data="@GetDataDrivenTimeSeries(widget)" Height="100%">
                <BbXAxis DataKey="month" />
                <BbYAxis Show="false" />
                <BbChartTooltip />
                <BbLine DataKey="value" Name="@widget.Title" Color="var(--chart-3)" Curve="CurveType.Smooth" />
            </BbLineChart>
        },
        "pie-chart" => __builder =>
        {
            <BbPieChart Data="@GetDataDrivenCategories(widget)" Height="100%">
                <BbChartTooltip />
                <BbChartLegend />
                <BbPie DataKey="value" NameKey="name" />
            </BbPieChart>
        },
        "kpi" => __builder =>
        {
            var kpi = GetDataDrivenKpi(widget);
            <div class="flex flex-col items-center justify-center h-full gap-1">
                <span class="text-4xl font-bold tracking-tight">@kpi.Value</span>
                <span class="text-sm text-muted-foreground">@kpi.Label</span>
                @if (kpi.Change != null)
                {
                    var isPositive = kpi.Change.StartsWith("+");
                    <span class="text-xs @(isPositive ? "text-green-500" : "text-red-500")">
                        @kpi.Change from last month
                    </span>
                }
            </div>
        },
        "table" => __builder =>
        {
            var rows = GetDataDrivenTableRows(widget);
            <div class="overflow-auto h-full">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b text-left text-muted-foreground">
                            <th class="py-2 px-3 font-medium">Name</th>
                            <th class="py-2 px-3 font-medium text-right">Value</th>
                            <th class="py-2 px-3 font-medium text-right">Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows)
                        {
                            <tr class="border-b last:border-0">
                                <td class="py-2 px-3">@row.Name</td>
                                <td class="py-2 px-3 text-right font-medium">@row.Value</td>
                                <td class="py-2 px-3 text-right @(row.IsPositive ? "text-green-500" : "text-red-500")">
                                    @row.Change
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        },
        _ => @<div class="flex items-center justify-center h-full text-muted-foreground text-sm">Unknown widget type: @widget.Type</div>
    };

