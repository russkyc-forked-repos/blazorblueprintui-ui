    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Data-Driven Dashboard</h2>
            <p class="text-sm text-muted-foreground">
                A fully data-driven dashboard where widget layout and content are loaded from JSON
                at runtime — simulating a backend API call. Users can rearrange, resize, and remove
                widgets, then save the layout back to JSON for persistence.
            </p>
            <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl">
                This pattern separates <strong>layout</strong> (positions on the grid) from
                <strong>widget configuration</strong> (what each widget displays). Both are stored
                together in a single JSON payload and loaded on demand. The grid manages spatial
                positioning while your code maps widget types to Blazor content.
            </p>
        </div>

        <div class="flex flex-wrap gap-2">
            @if (!dataDrivenLoaded)
            {
                <BbButton OnClick="LoadDataDrivenDashboard" Variant="ButtonVariant.Default" Size="ButtonSize.Small">
                    <LucideIcon Name="download" Class="h-4 w-4 mr-2" /> Load Dashboard
                </BbButton>
            }
            else
            {
                <BbButton OnClick="SaveDataDrivenDashboard" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                    <LucideIcon Name="save" Class="h-4 w-4 mr-2" /> Save Layout
                </BbButton>
                <BbButton OnClick="UnloadDataDrivenDashboard" Variant="ButtonVariant.Destructive" Size="ButtonSize.Small">
                    <LucideIcon Name="x" Class="h-4 w-4 mr-2" /> Unload
                </BbButton>
            }
        </div>

        <BbDashboardGrid @ref="dataDrivenGridRef" @bind-State="dataDrivenGridState"
                         Loading="@dataDrivenLoading" Background="DashboardBackground.Grid" Border="true">
            @foreach (var widget in dataDrivenWidgets)
            {
                <BbDashboardWidget @key="widget.Id" Id="@widget.Id"
                                  Column="@widget.Column" Row="@widget.Row"
                                  ColumnSpan="@widget.ColSpan" RowSpan="@widget.RowSpan"
                                  Title="@widget.Title" OnRemove="RemoveDataDrivenWidget">
                    @RenderDataDrivenWidgetContent(widget)
                </BbDashboardWidget>
            }
        </BbDashboardGrid>

        @if (dataDrivenSavedJson != null)
        {
            <div class="space-y-2">
                <h3 class="text-sm font-semibold">Saved JSON</h3>
                <pre class="text-xs bg-muted p-4 rounded-lg overflow-auto max-h-60">@dataDrivenSavedJson</pre>
            </div>
        }
        <CodeBlock Source="Components/DashboardGrid/data-driven.txt" />
