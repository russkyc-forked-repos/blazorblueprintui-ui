@code {
    private List<Person> people = new();
    private List<Person> manyPeople = new();
    private List<Person> stressTestPeople = new();
    private List<Person> asyncPeople = new();
    private IReadOnlyCollection<Person> _selectedPeople = Array.Empty<Person>();
    private string? clickedRowMessage;
    private bool _isLoading;
    private bool stressTestLoaded;
    private bool stressTestLoading;

    // Column Filtering demo state
    private BlazorBlueprint.Primitives.DataGrid.DataGridState<Person> _gridState = new();

    // Expandable nested table demo data
    private record Subtask(string Title, string Assignee, string Status, int EstimatedHours);
    private record ProjectTask(string Title, string Assignee, string Status, string Priority, List<Subtask> Subtasks);

