                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-striped-rows.txt" />
        </div>

        <!-- Striped Columns -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Striped Columns</h3>
                <p class="text-sm text-muted-foreground">
                    Apply <code class="bg-muted px-1 py-0.5 rounded">CellClass</code> and
                    <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> to alternating
                    columns for a vertical stripe effect.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5">
                <Columns>
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Name)" Sortable
                        CellClass="bg-muted" HeaderClass="bg-muted" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Department)" Sortable />
                    <BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)" Format="C0" Sortable
                        CellClass="bg-muted" HeaderClass="bg-muted" />
                    <BbDataGridPropertyColumn TData="Person" TProp="string" Property="@(p => p.Status)" />
                </Columns>
            </BbDataGrid>
            <CodeBlock Source="Components/DataGrid/custom-striped-columns.txt" />
        </div>

        <!-- Colored Header -->
        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Colored Header</h3>
