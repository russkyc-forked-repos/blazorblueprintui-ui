        <div class="space-y-4">
            <div class="space-y-1">
                <h3 class="text-lg font-medium">Grid Lines</h3>
                <p class="text-sm text-muted-foreground">
                    Add visible row and column borders. Apply <code class="bg-muted px-1 py-0.5 rounded">border-r</code>
                    via <code class="bg-muted px-1 py-0.5 rounded">CellClass</code> and
                    <code class="bg-muted px-1 py-0.5 rounded">HeaderClass</code> on each column,
                    and wrap the grid in an outer border with <code class="bg-muted px-1 py-0.5 rounded">Class</code>.
                </p>
            </div>
            <BbDataGrid TData="Person" Items="@people" InitialPageSize="5"
                       Class="border border-border rounded-lg overflow-hidden">
