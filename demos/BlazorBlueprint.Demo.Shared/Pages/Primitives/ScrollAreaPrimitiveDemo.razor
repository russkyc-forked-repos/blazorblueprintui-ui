@page "/primitives/scroll-area"
<PageTitle>Scroll Area Primitive - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-4xl">
    <div>
        <div class="space-y-3">
            <h1 class="text-4xl font-bold tracking-tight">Scroll Area Primitive</h1>
            <p class="text-xl text-muted-foreground">
                Headless, unstyled scroll area with custom scrollbar, ARIA scrollbar role, and drag-to-scroll support.
            </p>
        </div>
    </div>

    <div class="space-y-6">
        <section class="space-y-4">
            <div class="space-y-2">
                <h2 class="text-2xl font-semibold">Vertical Scroll</h2>
                <p class="text-muted-foreground">
                    A composable scroll area with Viewport, Scrollbar, and Thumb sub-components.
                    The scrollbar includes <code class="bg-muted px-1 py-0.5 rounded">role="scrollbar"</code> with full ARIA attributes.
                </p>
            </div>

            <div class="rounded-lg border bg-card p-6">
                <BlazorBlueprint.Primitives.ScrollArea.BbScrollArea
                    style="position: relative; overflow: hidden; height: 200px; width: 350px; border: 1px solid var(--border); border-radius: 0.375rem;">
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport
                        style="padding: 1rem;">
                        <h4 style="font-size: 0.875rem; font-weight: 500; margin-bottom: 1rem;">Tags</h4>
                        @foreach (var tag in tags)
                        {
                            <div style="font-size: 0.875rem; padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
                                @tag
                            </div>
                        }
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport>
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                        Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Vertical"
                        style="display: flex; touch-action: none; user-select: none; width: 10px; padding: 1px; border-left: 1px solid transparent;">
                        <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb
                            style="position: relative; flex: 1; border-radius: 9999px; background-color: var(--border);" />
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
                </BlazorBlueprint.Primitives.ScrollArea.BbScrollArea>
            </div>
        </section>

        <section class="space-y-4">
            <div class="space-y-2">
                <h2 class="text-2xl font-semibold">Horizontal Scroll</h2>
                <p class="text-muted-foreground">
                    Scroll area configured for horizontal scrolling.
                </p>
            </div>

            <div class="rounded-lg border bg-card p-6">
                <BlazorBlueprint.Primitives.ScrollArea.BbScrollArea
                    Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Horizontal"
                    style="position: relative; overflow: hidden; width: 100%; border: 1px solid var(--border); border-radius: 0.375rem;">
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport
                        style="padding: 1rem;">
                        <div style="display: flex; gap: 1rem; width: max-content;">
                            @for (var i = 1; i <= 12; i++)
                            {
                                <div style="flex-shrink: 0; width: 200px; height: 120px; background-color: var(--muted); border-radius: 0.375rem; display: flex; align-items: center; justify-content: center;">
                                    <span style="font-size: 1.125rem; font-weight: 600;">Image @i</span>
                                </div>
                            }
                        </div>
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport>
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                        Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Horizontal"
                        style="display: flex; flex-direction: column; touch-action: none; user-select: none; height: 10px; padding: 1px; border-top: 1px solid transparent;">
                        <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb
                            style="position: relative; flex: 1; border-radius: 9999px; background-color: var(--border);" />
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
                </BlazorBlueprint.Primitives.ScrollArea.BbScrollArea>
            </div>
        </section>

        <section class="space-y-4">
            <div class="space-y-2">
                <h2 class="text-2xl font-semibold">Both Axes</h2>
                <p class="text-muted-foreground">
                    Scroll area with both vertical and horizontal scrollbars.
                </p>
            </div>

            <div class="rounded-lg border bg-card p-6">
                <BlazorBlueprint.Primitives.ScrollArea.BbScrollArea
                    Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Both"
                    style="position: relative; overflow: hidden; height: 250px; width: 400px; border: 1px solid var(--border); border-radius: 0.375rem;">
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport
                        style="padding: 1rem;">
                        <div style="width: 800px;">
                            @for (var i = 0; i < 30; i++)
                            {
                                <div style="font-size: 0.875rem; padding: 0.25rem 0; white-space: nowrap;">
                                    Row @(i + 1) — This is a wide row with enough content to require horizontal scrolling in the container.
                                </div>
                            }
                        </div>
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaViewport>
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                        Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Vertical"
                        style="display: flex; touch-action: none; user-select: none; width: 10px; padding: 1px; border-left: 1px solid transparent;">
                        <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb
                            style="position: relative; flex: 1; border-radius: 9999px; background-color: var(--border);" />
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
                    <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar
                        Orientation="BlazorBlueprint.Primitives.ScrollArea.ScrollAreaOrientation.Horizontal"
                        style="display: flex; flex-direction: column; touch-action: none; user-select: none; height: 10px; padding: 1px; border-top: 1px solid transparent;">
                        <BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaThumb
                            style="position: relative; flex: 1; border-radius: 9999px; background-color: var(--border);" />
                    </BlazorBlueprint.Primitives.ScrollArea.BbScrollAreaScrollbar>
                </BlazorBlueprint.Primitives.ScrollArea.BbScrollArea>
            </div>
        </section>
    </div>

    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Component Structure</h2>
            <p class="text-muted-foreground">
                The scroll area is composed of four sub-components.
            </p>
        </div>

        <div class="rounded-lg border p-6 space-y-4 bg-muted/30">
            <pre class="text-sm"><code>&lt;BbScrollArea&gt;
    &lt;BbScrollAreaViewport&gt;
        &lt;!-- Scrollable content --&gt;
    &lt;/BbScrollAreaViewport&gt;
    &lt;BbScrollAreaScrollbar Orientation="Vertical"&gt;
        &lt;BbScrollAreaThumb /&gt;
    &lt;/BbScrollAreaScrollbar&gt;
&lt;/BbScrollArea&gt;</code></pre>
        </div>
    </section>

    <!-- API Reference -->
    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">API Reference</h2>
            <p class="text-muted-foreground">Component properties and parameters.</p>
        </div>
        <div class="space-y-4">
            <ApiReference ComponentName="BbScrollArea">
                <ApiParameter Name="Orientation" Type="ScrollAreaOrientation" Default="Vertical">
                    The scroll orientation. Options: Vertical, Horizontal, or Both.
                </ApiParameter>
            </ApiReference>

            <ApiReference ComponentName="BbScrollAreaScrollbar">
                <ApiParameter Name="Orientation" Type="ScrollAreaOrientation" Default="Vertical">
                    The scrollbar orientation. Must match the scroll direction it controls.
                </ApiParameter>
            </ApiReference>
        </div>
    </section>

    <!-- Accessibility Notes -->
    <AccessibilityList>
        <AriaAttributes>
            <AccessibilityItem>
                Scrollbar uses <code class="bg-muted px-1 py-0.5 rounded">role="scrollbar"</code> with <code class="bg-muted px-1 py-0.5 rounded">aria-controls</code> pointing to the viewport
            </AccessibilityItem>
            <AccessibilityItem>
                Includes <code class="bg-muted px-1 py-0.5 rounded">aria-valuenow</code>, <code class="bg-muted px-1 py-0.5 rounded">aria-valuemin</code>, and <code class="bg-muted px-1 py-0.5 rounded">aria-valuemax</code> for scroll position
            </AccessibilityItem>
            <AccessibilityItem>
                <code class="bg-muted px-1 py-0.5 rounded">aria-orientation</code> reflects the scrollbar direction
            </AccessibilityItem>
        </AriaAttributes>
        <KeyboardNavigation>
            <KeyboardShortcutItem Description="Scroll content up/down or left/right">
                <BbKbd>Arrow Keys</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="Scroll by page">
                <BbKbd>PageUp</BbKbd> / <BbKbd>PageDown</BbKbd>
            </KeyboardShortcutItem>
        </KeyboardNavigation>
    </AccessibilityList>
</div>

@code {
    private readonly string[] tags =
    [
        "React", "Vue", "Angular", "Svelte", "Blazor",
        "Next.js", "Nuxt", "Gatsby", "Remix", "Astro",
        "TypeScript", "JavaScript", "C#", "Python", "Go",
        "Rust", "Kotlin", "Swift", "Ruby", "PHP"
    ];
}
