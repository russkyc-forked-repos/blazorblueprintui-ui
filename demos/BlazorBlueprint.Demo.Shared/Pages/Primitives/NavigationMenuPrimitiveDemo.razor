@page "/primitives/navigation-menu"
<PageTitle>Navigation Menu Primitive - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-4xl">
    <div>
        <div class="space-y-3">
            <h1 class="text-4xl font-bold tracking-tight">Navigation Menu Primitive</h1>
            <p class="text-xl text-muted-foreground">
                Headless navigation menu with hover-to-open dropdowns, close timers, and ARIA semantics.
            </p>
        </div>
    </div>

    <div class="space-y-6">
        <section class="space-y-4">
            <div class="space-y-2">
                <h2 class="text-2xl font-semibold">Basic Navigation Menu</h2>
                <p class="text-muted-foreground">
                    A headless navigation menu with dropdown items and direct links.
                    Hover opens dropdowns with a shared close timer to prevent flickering.
                    Navigation events automatically close open menus.
                </p>
            </div>

            <div class="rounded-lg border bg-card p-6">
                <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenu
                    class="relative flex max-w-max items-center">
                    <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuList
                        class="flex list-none items-center gap-1">
                        <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuItem Value="getting-started">
                            <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuTrigger
                                class="inline-flex h-10 items-center justify-center rounded-md px-4 py-2 text-sm font-medium hover:bg-accent data-[state=open]:bg-accent/50 transition-colors">
                                Getting Started
                            </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuTrigger>
                            <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuContent
                                class="absolute left-0 top-full mt-1.5 z-50 w-[400px] rounded-md border bg-popover p-4 text-popover-foreground shadow-lg">
                                <div class="grid gap-3">
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Introduction</h3>
                                        <p class="text-sm text-muted-foreground">Learn the basics of BlazorBlueprint primitives.</p>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Installation</h3>
                                        <p class="text-sm text-muted-foreground">How to install and configure the library.</p>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Architecture</h3>
                                        <p class="text-sm text-muted-foreground">Understand the two-layer component design.</p>
                                    </div>
                                </div>
                            </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuContent>
                        </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuItem>

                        <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuItem Value="components">
                            <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuTrigger
                                class="inline-flex h-10 items-center justify-center rounded-md px-4 py-2 text-sm font-medium hover:bg-accent data-[state=open]:bg-accent/50 transition-colors">
                                Components
                            </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuTrigger>
                            <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuContent
                                class="absolute left-0 top-full mt-1.5 z-50 w-[500px] rounded-md border bg-popover p-4 text-popover-foreground shadow-lg">
                                <div class="grid grid-cols-2 gap-3">
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Button</h3>
                                        <p class="text-sm text-muted-foreground">Displays a button or link.</p>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Dialog</h3>
                                        <p class="text-sm text-muted-foreground">Modal dialog with overlay.</p>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Tabs</h3>
                                        <p class="text-sm text-muted-foreground">Tabbed content interface.</p>
                                    </div>
                                    <div class="space-y-1">
                                        <h3 class="text-sm font-medium leading-none">Tooltip</h3>
                                        <p class="text-sm text-muted-foreground">Popup info on hover.</p>
                                    </div>
                                </div>
                            </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuContent>
                        </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuItem>

                        <li>
                            <BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuLink
                                Href="/primitives"
                                class="inline-flex h-10 items-center justify-center rounded-md px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                                Documentation
                            </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuLink>
                        </li>
                    </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenuList>
                </BlazorBlueprint.Primitives.NavigationMenu.BbNavigationMenu>
            </div>

            <CodeBlock Source="Primitives/NavigationMenu/basic.txt" />
        </section>

        <!-- Accessibility Notes -->
        <AccessibilityList>
            <AriaAttributes>
                <AccessibilityItem>
                    Root renders as <code class="text-xs bg-muted px-1 py-0.5 rounded">&lt;nav&gt;</code> for semantic navigation
                </AccessibilityItem>
                <AccessibilityItem>
                    <code class="text-xs bg-muted px-1 py-0.5 rounded">aria-haspopup="menu"</code> and <code class="text-xs bg-muted px-1 py-0.5 rounded">aria-expanded</code> on triggers
                </AccessibilityItem>
                <AccessibilityItem>
                    <code class="text-xs bg-muted px-1 py-0.5 rounded">role="menu"</code> on content panels
                </AccessibilityItem>
                <AccessibilityItem>
                    <code class="text-xs bg-muted px-1 py-0.5 rounded">role="menuitem"</code> on navigation links
                </AccessibilityItem>
                <AccessibilityItem>
                    <code class="text-xs bg-muted px-1 py-0.5 rounded">data-state="open|closed"</code> for CSS animation hooks
                </AccessibilityItem>
            </AriaAttributes>
            <KeyboardNavigation>
                <KeyboardShortcutItem Description="Hover opens dropdowns with a 150ms close delay to prevent flickering">
                    <BbKbd>Hover</BbKbd>
                </KeyboardShortcutItem>
                <KeyboardShortcutItem Description="Route changes automatically close open menus">
                    <BbKbd>Navigate</BbKbd>
                </KeyboardShortcutItem>
            </KeyboardNavigation>
        </AccessibilityList>
    </div>
</div>
