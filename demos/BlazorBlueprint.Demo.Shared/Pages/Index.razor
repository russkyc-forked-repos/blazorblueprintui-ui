@page "/"

<PageTitle>Blazor Blueprint - Home</PageTitle>

<div class="space-y-10">
    <!-- Hero -->
    <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">BlazorBlueprint</h1>
        <p class="text-xl text-muted-foreground max-w-3xl">
            The leading Blazor UI framework for bringing the shadcn/ui design system to Blazor. Modern, beautifully designed components extended with enterprise-class additions like <a href="/components/datagrid" class="font-medium text-foreground underline underline-offset-4 hover:text-primary">Data Grid</a>, Dynamic Form Builder, <a href="/components/filterbuilder" class="font-medium text-foreground underline underline-offset-4 hover:text-primary">Filter Builder</a>, and more.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
            <BbButton Variant="ButtonVariant.Default" Href="https://blazorblueprintui.com?utm_source=demo" Target="_blank">
                Visit blazorblueprintui.com
                <LucideIcon Name="external-link" Class="ml-1 h-4 w-4" />
            </BbButton>
            <BbButton Variant="ButtonVariant.Outline" Href="/components">
                Explore Components
            </BbButton>
            <BbButton Variant="ButtonVariant.Outline" Href="/primitives">
                Explore Primitives
            </BbButton>
        </div>
    </div>

    <!-- Two-Layer Architecture -->
    <div class="space-y-4">
        <h2 class="text-2xl font-semibold">Two-Layer Architecture</h2>
        <div class="grid gap-4 md:grid-cols-2">
            <div class="p-6 border rounded-lg space-y-3 bg-card">
                <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                        <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                        <path d="M9 3v18"></path>
                    </svg>
                    <h3 class="text-lg font-semibold">Primitives</h3>
                </div>
                <p class="text-sm text-muted-foreground">
                    Unstyled, headless building blocks that handle behavior, accessibility, and state management.
                    Use them to construct your own design system with full control over markup and styling.
                </p>
                <a href="/primitives" class="text-sm text-primary hover:underline">Explore Primitives</a>
            </div>

            <div class="p-6 border rounded-lg space-y-3 bg-card">
                <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                        <path d="m7.5 4.27 9 5.15"></path>
                        <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"></path>
                        <path d="m3.3 7 8.7 5 8.7-5"></path>
                        <path d="M12 22V12"></path>
                    </svg>
                    <h3 class="text-lg font-semibold">Components</h3>
                </div>
                <p class="text-sm text-muted-foreground">
                    Pre-styled components built on Primitives with the shadcn/ui look and feel.
                    Drop them into any Blazor app for a polished, modern UI out of the box.
                </p>
                <a href="/components" class="text-sm text-primary hover:underline">Explore Components</a>
            </div>
        </div>
    </div>

    <!-- shadcn/ui Compatibility -->
    <div class="space-y-4">
        <h2 class="text-2xl font-semibold">Full shadcn/ui Compatibility</h2>
        <div class="p-6 border rounded-lg space-y-4 bg-card">
            <p class="text-muted-foreground">
                Blazor Blueprint is the first Blazor component library designed from the ground up to be fully compatible
                with the <strong class="text-foreground">shadcn/ui design system</strong>. Every component shares the same
                design tokens, CSS variables, and visual language used by shadcn/ui in the React ecosystem.
            </p>
            <p class="text-muted-foreground">
                Beyond shadcn/ui parity, Blazor Blueprint includes additional enterprise-grade components that go further:
                <a href="/components/datagrid" class="font-medium text-foreground underline underline-offset-4 hover:text-primary">Data Grid</a> with sorting, pagination, and column pinning;
                <strong class="text-foreground">Dynamic Form Builder</strong> for schema-driven forms;
                <a href="/components/filterbuilder" class="font-medium text-foreground underline underline-offset-4 hover:text-primary">Filter Builder</a> for visual query construction;
                <a href="/components/currency-input" class="font-medium text-foreground underline underline-offset-4 hover:text-primary">Currency Input</a> with 40+ locale-aware currencies;
                and many more.
            </p>
        </div>
    </div>

    <!-- Key Features -->
    <div class="space-y-4">
        <h2 class="text-2xl font-semibold">Key Features</h2>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <path d="m7.5 4.27 9 5.15"></path>
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"></path>
                    <path d="m3.3 7 8.7 5 8.7-5"></path>
                    <path d="M12 22V12"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">Modern Design</h4>
                    <p class="text-sm text-muted-foreground">Clean, contemporary look that matches the shadcn/ui aesthetic your users already know and love.</p>
                </div>
            </div>

            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                    <path d="M3 9h18"></path>
                    <path d="M9 21V9"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">Enterprise Components</h4>
                    <p class="text-sm text-muted-foreground"><a href="/components/datagrid" class="text-muted-foreground underline underline-offset-4 hover:text-foreground">Data Grid</a>, Dynamic Form Builder, <a href="/components/filterbuilder" class="text-muted-foreground underline underline-offset-4 hover:text-foreground">Filter Builder</a>, and other advanced components for real-world applications.</p>
                </div>
            </div>

            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path>
                    <path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">Accessible by Default</h4>
                    <p class="text-sm text-muted-foreground">Keyboard navigation, ARIA attributes, focus management, and semantic HTML baked into every component.</p>
                </div>
            </div>

            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                    <path d="M12 8v8"></path>
                    <path d="M8 12h8"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">Primitives as Building Blocks</h4>
                    <p class="text-sm text-muted-foreground">Headless primitives give you full control to build your own components with behavior and accessibility handled for you.</p>
                </div>
            </div>

            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 16v-4"></path>
                    <path d="M12 8h.01"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">Type-Safe C#</h4>
                    <p class="text-sm text-muted-foreground">Full compile-time type checking and IntelliSense support. No stringly-typed APIs.</p>
                </div>
            </div>

            <div class="flex items-start gap-3 p-4 border rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-primary flex-shrink-0">
                    <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                    <path d="m9 12 2 2 4-4"></path>
                </svg>
                <div class="space-y-1">
                    <h4 class="font-medium">All Render Modes</h4>
                    <p class="text-sm text-muted-foreground">Works with Blazor Server, WebAssembly, and Auto render modes on .NET 8+.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Getting Started -->
    <div class="space-y-4">
        <h2 class="text-2xl font-semibold">Getting Started</h2>
        <div class="p-6 border rounded-lg space-y-4 bg-muted/50">
            <p class="text-muted-foreground">
                Explore the sidebar to browse all available primitives and components. Each demo page includes
                interactive examples, code snippets, accessibility details, and a full API reference.
            </p>
            <div class="flex flex-wrap gap-3">
                <BbButton Variant="ButtonVariant.Default" Href="/architecture">
                    View Architecture
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" Href="/components">
                    Explore Components
                </BbButton>
                <BbButton Variant="ButtonVariant.Outline" Href="/primitives">
                    Explore Primitives
                </BbButton>
                <BbButton Variant="ButtonVariant.Ghost" Href="https://blazorblueprintui.com?utm_source=demo" Target="_blank">
                    blazorblueprintui.com
                    <LucideIcon Name="external-link" Class="ml-1 h-4 w-4" />
                </BbButton>
            </div>
        </div>
    </div>
</div>
